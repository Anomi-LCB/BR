dayEncouragement.emoji}</div>\r\n                <div className=\"min-w-0\">\r\n                    <p className=\"text-sm font-medium text-foreground/90 leading-relaxed\">\r\n                        {todayEncouragement.msg}\r\n                    </p>\r\n                    <p className=\"text-[10px] text-muted-foreground mt-1.5 italic\">\r\n                        {todayEncouragement.sub}\r\n                    </p>\r\n                </div>\r\n            </div>\r\n        </SmartCard>\r\n    );\r\n}\r\n\r\nexport default function BibleDashboard({\r\n    user,\r\n    allPlans,\r\n    // initialProgress, // Unused\r\n    // appSettings, // Unused\r\n    initialDate,\r\n    rawTargetPlan: initialRawTargetPlan\r\n}: BibleDashboardProps) {\r\n    const searchParams = useSearchParams();\r\n    // const isGuest = true; // Unused\r\n    const [activeTab, setActiveTab] = useState<Tab>(\"home\");\r\n    const [onlineCount, setOnlineCount] = useState(0);\r\n\r\n    // Swipe navigation\r\n    const tabOrder = useMemo<Tab[]>(() => [\"home\", \"streak\", \"challenge\", \"bible\", \"calendar\", \"menu\"], []);\r\n    const touchStartX = useRef<number>(0);\r\n    const touchStartY = useRef<number>(0);\r\n    const mainRef = useRef<HTMLDivElement>(null);\r\n\r\n    const handleTouchStart = useCallback((e: React.TouchEvent) => {\r\n        touchStartX.current = e.touches[0].clientX;\r\n        touchStartY.current = e.touches[0].clientY;\r\n    }, []);\r\n\r\n    const handleTouchEnd = useCallback((e: React.TouchEvent) => {\r\n        const deltaX = e.changedTouches[0].clientX - touchStartX.current;\r\n        const deltaY = e.changedTouches[0].clientY - touchStartY.current;\r\n        // Only trigger if horizontal swipe is dominant and significant\r\n        if (Math.abs(deltaX) > 60 && Math.abs(deltaX) > Math.abs(deltaY) * 1.5) {\r\n            const currentIndex = tabOrder.indexOf(activeTab);\r\n            if (deltaX < 0 && currentIndex < tabOrder.length - 1) {\r\n                // Swipe left ??next tab\r\n                setActiveTab(tabOrder[currentIndex + 1]);\r\n            } else if (deltaX > 0 && currentIndex > 0) {\r\n                // Swipe right ??previous tab\r\n                setActiveTab(tabOrder[currentIndex - 1]);\r\n            }\r\n        }\r\n    }, [activeTab, tabOrder]);\r\n\r\n    // State\r\n    const [selectedDate, setSelectedDate] = useState(initialDate);\r\n    const [videoDuration, setVideoDuration] = useState<number | null>(null);\r\n\r\n    // Global Store\r\n    const {\r\n        completedPlanIds,\r\n        toggleReading,\r\n        loadInitialData,\r\n        isSyncing\r\n    } = useBibleStore();\r\n\r\n    // Settings from localStorage\r\n    const [fontSize, setFontSize] = useState<'small' | 'medium' | 'large'>('medium');\r\n    const [autoPlay, setAutoPlay] = useState(false);\r\n    const [showEncouragement, setShowEncouragement] = useState(true);\r\n\r\n    // Achievement State\r\n    const [achievements, setAchievements] = useState<Achievement[]>([]);\r\n    const [newBadge, setNewBadge] = useState<Badge | null>(null);\r\n\r\n    // Apply global font size as CSS custom property\r\n    useEffect(() => {\r\n        const applyFontSize = () => {\r\n            const size = localStorage.getItem('bible_font_size') || 'medium';\r\n            setFontSize(size as 'small' | 'medium' | 'large');\r\n            const scales: Record<string, string> = { small: '0.88', medium: '1', large: '1.15' };\r\n            document.documentElement.style.setProperty('--font-scale', scales[size] || '1');\r\n        };\r\n\r\n        applyFontSize();\r\n        // Move state updates that read from localStorage to here\r\n        // Note: setting state in useEffect is okay for initialization from external sources like localStorage\r\n        // eslint-disable-next-line react-hooks/set-state-in-effect\r\n        setAutoPlay(localStorage.getItem('bible_autoplay') === 'true');\r\n        // eslint-disable-next-line react-hooks/set-state-in-effect\r\n        setShowEncouragement(localStorage.getItem('bible_daily_verse') !== 'false');\r\n\r\n        // Initialize Store\r\n        loadInitialData(user?.id);\r\n\r\n        if (user?.id) {\r\n            // Trigger Sync (Local -> Cloud)\r\n            const { syncWithSupabase } = useBibleStore.getState();\r\n            syncWithSupabase(user.id);\r\n        }\r\n\r\n        // Listen for font-size changes from Settings tab\r\n        window.addEventListener('bible-font-change', applyFontSize);\r\n\r\n        // Load achievements\r\n        setAchievements(loadAchievements());\r\n\r\n        return () => window.removeEventListener('bible-font-change', applyFontSize);\r\n    }, [user, loadInitialData]);\r\n\r\n    // Sync with URL\r\n    useEffect(() => {\r\n        const dateFromUrl = searchParams.get(\"date\");\r\n        if (dateFromUrl && dateFromUrl !== selectedDate) {\r\n            // eslint-disable-next-line react-hooks/set-state-in-effect\r\n            setSelectedDate(dateFromUrl);\r\n        }\r\n    }, [searchParams, selectedDate]);\r\n\r\n    // Fetch YouTube Video Duration for the selected date\r\n    useEffect(() => {\r\n        async function fetchDuration() {\r\n            try {\r\n                // Calculate Day of Year\r\n                const dateObj = new Date(selectedDate);\r\n                const startYear = new Date(dateObj.getFullYear(), 0, 0);\r\n                const diff = dateObj.getTime() - startYear.getTime();\r\n                const oneDay = 1000 * 60 * 60 * 24;\r\n                const dayOfYear = Math.floor(diff / oneDay);\r\n\r\n                const videos = await fetchYoutubePlaylist();\r\n                const videoData = getVideoForDay(videos, dayOfYear);\r\n                if (videoData && videoData.duration) {\r\n                    setVideoDuration(parseDurationToMinutes(videoData.duration));\r\n                } else {\r\n                    setVideoDuration(null);\r\n                }\r\n            } catch (error) {\r\n                console.error(\"Failed to fetch video duration\", error);\r\n            }\r\n        }\r\n        fetchDuration();\r\n    }, [selectedDate]);\r\n\r\n\r\n\r\n    const handleDateChange = (newDateStr: string) => {\r\n        setSelectedDate(newDateStr);\r\n        const url = new URL(window.location.href);\r\n        url.searchParams.set(\"date\", newDateStr);\r\n        window.history.pushState({}, \"\", url.toString());\r\n    };\r\n\r\n    // Derived State from Store\r\n    const { streak, completedVerses, completedIds, progressPercent, daysLeft } = useMemo(() => {\r\n        // Map store IDs back to full plan objects if needed, but for stats we just need IDs\r\n        const currentCompletedIds = completedPlanIds;\r\n\r\n        // Calculate Streak based on dates of completed plans\r\n        const completedDates = allPlans\r\n            .filter(p => currentCompletedIds.includes(p.id))\r\n            .map(p => p.date)\r\n            .filter((d): d is string => !!d);\r\n\r\n        const streak = calculateStreak(completedDates);\r\n\r\n        const completedVerses = allPlans\r\n            .filter(p => currentCompletedIds.includes(p.id))\r\n            .reduce((acc: string[], p) => {\r\n                if (p.verses) acc.push(...p.verses);\r\n                return acc;\r\n            }, []);\r\n\r\n        const progressPercent = Math.round((currentCompletedIds.length / 365) * 100);\r\n        const daysLeft = 365 - currentCompletedIds.filter(id => id > 0).length;\r\n\r\n        return { streak, completedVerses, completedIds: currentCompletedIds, progressPercent, daysLeft };\r\n    }, [completedPlanIds, allPlans]);\r\n\r\n    // Target Plan Logic\r\n    const targetPlan = useMemo(() => {\r\n        let plan = initialRawTargetPlan;\r\n\r\n        if (selectedDate !== initialDate || !plan) {\r\n            const exact = allPlans.find(p => p.date === selectedDate);\r\n            const targetMMDD = selectedDate.slice(5);\r\n            plan = exact || allPlans.find(p => p.date && p.date.endsWith(targetMMDD));\r\n        }\r\n\r\n        if (!plan) return null;\r\n\r\n        // Psalm 119 Logic\r\n        const processedPlan = { ...plan };\r\n        const day = processedPlan.day_of_year;\r\n        const p119Mapping: Record<number, string> = {\r\n            119: \"?쒗렪 119??1~32??", 274: \"?쒗렪 119??1~32??",\r\n            120: \"?쒗렪 119??33-64??", 275: \"?쒗렪 119??33-64??",\r\n            121: \"?쒗렪 119??65-96??", 276: \"?쒗렪 119??65-96??",\r\n            122: \"?쒗렪 119??97-128??", 277: \"?쒗렪 119??97-128??",\r\n            123: \"?쒗렪 119??129-152??", 278: \"?쒗렪 119??129-152??",\r\n            124: \"?쒗렪 119??153-176??", 279: \"?쒗렪 119??153-176??"\r\n        };\r\n        const p119Text = p119Mapping[day];\r\n        if (p119Text && !processedPlan.title.includes(\"?쒗렪 119??")) {\r\n            processedPlan.title = `${processedPlan.title}, ${p119Text}`;\r\n            if (!processedPlan.verses.includes(p119Text)) {\r\n                processedPlan.verses = [...processedPlan.verses, p119Text];\r\n            }\r\n        }\r\n\r\n        return {\r\n            ...processedPlan,\r\n            category: processedPlan.category || getOfficialCategory(processedPlan.verses),\r\n            summary: processedPlan.summary || generateKeywords(processedPlan.verses),\r\n            reading_time: processedPlan.reading_time || calculateReadingTime(processedPlan.verses)\r\n        };\r\n    }, [allPlans, selectedDate, initialDate, initialRawTargetPlan]);\r\n\r\n    // Presence Logic (Live User Count)\r\n    useEffect(() => {\r\n        const supabase = createClient();\r\n        const start = Date.now();\r\n        const channel = supabase.channel('global_reading_room', {\r\n            config: { presence: { key: user?.id || `guest-${Math.random().toString(36).slice(2)}` } }\r\n        });\r\n\r\n        channel\r\n            .on('presence', { event: 'sync' }, () => {\r\n                const state = channel.presenceState();\r\n                setOnlineCount(Object.keys(state).length);\r\n            })\r\n            .subscribe(async (status: 'SUBSCRIBED' | 'TIMED_OUT' | 'POSTGRES_CHANGES_FAILURE' | 'CHANNEL_ERROR' | 'CLOSED') => {\r\n                if (status === 'SUBSCRIBED') {\r\n                    await channel.track({\r\n                        online_at: new Date().toISOString(),\r\n                        is_member: !!user,\r\n                        plan_id: targetPlan?.id\r\n                    });\r\n                }\r\n            });\r\n\r\n        return () => {\r\n            supabase.removeChannel(channel);\r\n        };\r\n    }, [user, targetPlan?.id]);\r\n\r\n    // Broadcast Activity to Group\r\n    const broadcastActivity = useCallback((type: 'start' | 'complete') => {\r\n        const groupId = localStorage.getItem('bible_group_id');\r\n        if (!groupId || !user) return;\r\n\r\n        const supabase = createClient();\r\n        supabase.channel(`group-${groupId}`).send({\r\n            type: 'broadcast',\r\n            event: 'activity',\r\n            payload: {\r\n                memberName: user.email?.split('@')[0] || '?듬챸',\r\n                type\r\n            }\r\n        });\r\n    }, [user]);\r\n\r\n    const isCompleted = targetPlan ? completedIds.includes(targetPlan.id) : false;\r\n\r\n    const handleToggle = async (planId: number) => {\r\n        const isNowCompleted = !isCompleted;\r\n\r\n        // 1. Dispatch Action\r\n        await toggleReading(planId, user?.id);\r\n\r\n        // 2. Broadcast\r\n        if (isNowCompleted) {\r\n            broadcastActivity('complete');\r\n        }\r\n\r\n        // 3. Achievement Check (Logic adapted for Store)\r\n        if (isNowCompleted) {\r\n            // Re-construct progress array for badge checker\r\n            const newProgress = [...completedPlanIds, planId].map(id => ({\r\n                plan_id: id,\r\n                reading_plan: allPlans.find(p => p.id === id)\r\n            })).filter(p => p.reading_plan);\r\n\r\n            const newEarned = checkNewAchievements(newProgress as UserProgress[], achievements);\r\n            if (newEarned.length > 0) {\r\n                // Celebration!\r\n                setNewBadge(newEarned[0]);\r\n                const updatedAchievements = [\r\n                    ...achievements,\r\n                    ...newEarned.map(b => ({ badge_id: b.id, earned_at: new Date().toISOString() }))\r\n                ];\r\n                setAchievements(updatedAchievements);\r\n                saveAchievements(updatedAchievements);\r\n            }\r\n        }\r\n    };\r\n\r\n    // End of logic, start of render\r\n\r\n    // State Refs for Notification Listener (avoid stale closures)\r\n    const targetPlanRef = useRef(targetPlan);\r\n    const streakRef = useRef(streak);\r\n    const progressRef = useRef(0); // will calculate below\r\n\r\n    // Calculate progress\r\n    const progress = useMemo(() => {\r\n        if (!allPlans.length) return 0;\r\n        return Math.round((completedPlanIds.length / allPlans.length) * 100);\r\n    }, [allPlans.length, completedPlanIds.length]);\r\n\r\n    // Update Refs\r\n    useEffect(() => {\r\n        targetPlanRef.current = targetPlan;\r\n        streakRef.current = streak;\r\n        progressRef.current = progress;\r\n    }, [targetPlan, streak, progress]);\r\n\r\n    // Handle Share ??shares YouTube URL instead of app link\r\n    const handleShare = async (forceTemplate?: \"reading\" | \"stats\") => {\r\n        const plan = targetPlanRef.current;\r\n        if (!plan && !forceTemplate) return;\r\n\r\n        const shareSettings = loadShareSettings();\r\n        const template = forceTemplate || shareSettings.template || \"reading\";\r\n\r\n        let data: Record<string, unknown>;\r\n        if (template === \"reading\") {\r\n            if (!plan) return;\r\n\r\n            // Fetch YouTube URL for today's reading\r\n            let youtubeUrl = '';\r\n            try {\r\n                const videos = await fetchYoutubePlaylist();\r\n                const dateObj = new Date(selectedDate);\r\n                const start = new Date(dateObj.getFullYear(), 0, 0);\r\n                const diff = dateObj.getTime() - start.getTime();\r\n                const dayOfYear = Math.floor(diff / (1000 * 60 * 60 * 24));\r\n                const video = getVideoForDay(videos, dayOfYear);\r\n                if (video) {\r\n                    youtubeUrl = `https://youtu.be/${video.videoId}`;\r\n                }\r\n            } catch (e) {\r\n                console.warn('Failed to get video URL for sharing', e);\r\n            }\r\n\r\n            data = { title: plan.title, verse: plan.verses[0], youtubeUrl };\r\n        } else {\r\n            data = { streak: streakRef.current, progress: progressRef.current };\r\n        }\r\n\r\n        const text = generateShareText(template, data);\r\n\r\n        // Route through correct share channel\r\n        if (shareSettings.channel === 'sms' && shareSettings.recipientPhones && shareSettings.recipientPhones.length > 0) {\r\n            await shareViaSMS(shareSettings.recipientPhones, text);\r\n        } else if (shareSettings.channel === 'kakao') {\r\n            await shareViaKakao(text);\r\n        } else {\r\n            await shareContent(\"?깃꼍 365\", text);\r\n        }\r\n    };\r\n\r\n    // Reschedule notifications on app load\r\n    useEffect(() => {\r\n        rescheduleFromSettings(\r\n            targetPlan?.title,\r\n            targetPlan?.verses?.[0]\r\n        ).catch(console.warn);\r\n\r\n        registerNotificationTapListener((action) => {\r\n            const extra = action.notification.extra;\r\n            if (extra?.type === \"share_reminder\") {\r\n                // Auto share on notification tap\r\n                setActiveTab(\"home\");\r\n                // Small delay to allow app to resume\r\n                setTimeout(() => handleShare(), 500);\r\n            } else {\r\n                setActiveTab(\"home\");\r\n            }\r\n        });\r\n    }, []); // eslint-disable-line react-hooks/exhaustive-deps\r\n\r\n    return (\r\n        <div className=\"min-h-screen bg-background\">\r\n            <HeaderIsland\r\n                title=\"?깃꼍 365\"\r\n                onLogoClick={() => setActiveTab(\"home\")}\r\n                onlineCount={onlineCount}\r\n                isSyncing={isSyncing}\r\n            />\r\n\r\n            <main\r\n                ref={mainRef}\r\n                className=\"container mx-auto px-4 max-w-2xl pt-20 pb-24\"\r\n                onTouchStart={handleTouchStart}\r\n                onTouchEnd={handleTouchEnd}\r\n            >\r\n                {activeTab === \"home\" && (\r\n                    <div className=\"animate-in fade-in slide-in-from-bottom-2 duration-500\">\r\n                        <DashboardGrid>\r\n                            {/* Date Navigation & Hero Card */}\r\n                            <GridCell span=\"3\" className=\"space-y-3\">\r\n                                <DateNavigator\r\n                                    currentDate={selectedDate}\r\n                                    onDateChange={handleDateChange}\r\n                                />\r\n                                {/* Share Button */}\r\n                                <div className=\"flex justify-end px-1\">\r\n                                    <button\r\n                                        onClick={() => handleShare()}\r\n                                        className=\"flex items-center gap-1.5 text-xs font-bold text-blue-500 bg-blue-500/10 px-3 py-1.5 rounded-full hover:bg-blue-500/20 transition-colors\"\r\n                                    >\r\n                                        <Share2 size={12} />\r\n                                        <span>?ㅻ뒛??留먯? 怨듭쑀</span>\r\n                                    </button>\r\n                                </div>\r\n                                {targetPlan ? (\r\n                                    <BibleCard\r\n                                        plan={targetPlan}\r\n                                        isCompleted={isCompleted}\r\n                                        onToggle={() => handleToggle(targetPlan.id)}\r\n                                        videoDuration={videoDuration}\r\n                                        fontSize={fontSize}\r\n                                    />\r\n                                ) : (\r\n                                    <SmartCard variant=\"outline\" className=\"p-12 text-center text-muted-foreground\">\r\n                                        ???좎쓽 ?쎄린?쒓? ?놁뒿?덈떎.\r\n                                    </SmartCard>\r\n                                )}\r\n                            </GridCell>\r\n\r\n                            {/* Streak Card */}\r\n                            <GridCell span=\"1\">\r\n                                <SmartCard\r\n                                    variant=\"elevated\"\r\n                                    className=\"h-full flex flex-col justify-between cursor-pointer hover:border-orange-500/30 transition-colors group\"\r\n                                    onClick={() => setActiveTab(\"streak\")}\r\n                                >\r\n                                    <div className=\"flex justify-between items-start\">\r\n                                        <span className=\"text-[10px] font-bold uppercase tracking-widest text-muted-foreground group-hover:text-orange-500 transition-colors\">?곗냽 ?쎄린</span>\r\n                                        <Flame size={16} className=\"text-orange-500\" />\r\n                                    </div>\r\n                                    <div>\r\n                                        <span className=\"text-2xl font-display font-medium\">{streak}</span>\r\n                                        <span className=\"text-xs text-muted-foreground ml-1\">?쇱㎏</span>\r\n                                    </div>\r\n                                </SmartCard>\r\n                            </GridCell>\r\n\r\n                            {/* Progress Card */}\r\n                            <GridCell span=\"1\">\r\n                                <SmartCard\r\n                                    variant=\"elevated\"\r\n                                    className=\"h-full flex flex-col justify-between cursor-pointer hover:border-primary/30 transition-colors group\"\r\n                                    onClick={() => setActiveTab(\"bible\")}\r\n                                >\r\n                                    <div className=\"flex justify-between items-start\">\r\n                                        <span className=\"text-[10px] font-bold uppercase tracking-widest text-muted-foreground group-hover:text-primary transition-colors\">吏꾪뻾瑜?/span>\r\n                                        <Trophy size={16} className=\"text-primary\" />\r\n                                    </div>\r\n                                    <div>\r\n                                        <span className=\"text-2xl font-display font-medium\">{progressPercent}%</span>\r\n                                        <span className=\"text-xs text-muted-foreground ml-1\">?꾨즺</span>\r\n                                    </div>\r\n                                </SmartCard>\r\n                            </GridCell>\r\n\r\n                            {/* Remaining Days Card */}\r\n                            <GridCell span=\"1\">\r\n                                <SmartCard\r\n                                    variant=\"elevated\"\r\n                                    className=\"h-full flex flex-col justify-between cursor-pointer hover:border-primary/30 transition-colors group\"\r\n                                    onClick={() => setActiveTab(\"calendar\")}\r\n                                >\r\n                                    <div className=\"flex justify-between items-start\">\r\n                                        <span className=\"text-[10px] font-bold uppercase tracking-widest text-muted-foreground group-hover:text-primary transition-colors\">?⑥? 湲곌컙</span>\r\n                                    </div>\r\n                                    <div>\r\n                                        <span className=\"text-2xl font-display font-medium\">{daysLeft}</span>\r\n                                        <span className=\"text-xs text-muted-foreground ml-1\">??/span>\r\n                                    </div>\r\n                                </SmartCard>\r\n                            </GridCell>\r\n\r\n                            {/* Audio Bible */}\r\n                            <GridCell span=\"3\" className=\"space-y-4\">\r\n                                <div className=\"flex items-center gap-2 mb-2\">\r\n                                    <h3 className=\"text-xs font-bold text-muted-foreground uppercase tracking-widest\">硫?곕??붿뼱 ?먮즺</h3>\r\n                                </div>\r\n                                <YoutubePlayer selectedDate={selectedDate} autoPlay={autoPlay} />\r\n                            </GridCell>\r\n\r\n                            {/* Encouragement Message */}\r\n                            {showEncouragement && (\r\n                                <GridCell span=\"3\">\r\n                                    <EncouragementBanner />\r\n                                </GridCell>\r\n                            )}\r\n                        </DashboardGrid>\r\n                    </div>\r\n                )}\r\n\r\n                {activeTab === \"streak\" && (\r\n                    <div className=\"animate-in fade-in slide-in-from-right-4 duration-500\">\r\n                        <StreakHistoryView\r\n                            progress={completedPlanIds.map(id => ({\r\n                                plan_id: id,\r\n                                reading_plan: allPlans.find(p => p.id === id)\r\n                            } as UserProgress)).filter(p => !!p.reading_plan)}\r\n                            onBack={() => setActiveTab(\"home\")}\r\n                        />\r\n                    </div>\r\n                )}\r\n\r\n                {activeTab === \"bible\" && (\r\n                    <div className=\"animate-in fade-in slide-in-from-right-4 duration-500\">\r\n                        <div className=\"flex items-center gap-3 mb-6 px-2\">\r\n                            <div className=\"p-2 rounded-full bg-primary/10\">\r\n                                <BookOpen size={20} className=\"text-primary\" />\r\n                            </div>\r\n                            <div>\r\n                                <h2 className=\"text-xl font-serif font-bold\">?깃꼍 ?쎄린 ?ъ젙</h2>\r\n                                <p className=\"text-xs text-muted-foreground\">66沅뚯쓽 紐⑤뱺 湲곕줉</p>\r\n                            </div>\r\n                        </div>\r\n                        <SmartCard variant=\"default\" padding=\"none\" className=\"bg-card/30 border border-border/50 dark:border-white/15\">\r\n                            <div className=\"p-4\">\r\n                                <BibleProgressMap completedVerses={completedVerses} />\r\n                            </div>\r\n                        </SmartCard>\r\n                    </div>\r\n                )}\r\n\r\n                {activeTab === \"calendar\" && (\r\n                    <div className=\"animate-in fade-in slide-in-from-right-4 duration-500\">\r\n                        <YearlyProgressView\r\n                            progress={completedPlanIds.map(id => ({\r\n                                plan_id: id,\r\n                                reading_plan: allPlans.find(p => p.id === id)\r\n                            } as UserProgress)).filter(p => !!p.reading_plan)}\r\n                            allPlans={allPlans}\r\n                            currentDate={selectedDate}\r\n                        />\r\n                    </div>\r\n                )}\r\n\r\n                {activeTab === \"menu\" && (\r\n                    <SettingsView />\r\n                )}\r\n\r\n                {activeTab === \"challenge\" && (\r\n                    <div className=\"animate-in fade-in slide-in-from-right-4 duration-500\">\r\n                        <GroupChallengeView user={user} streak={streak} progress={progressPercent} />\r\n                    </div>\r\n                )}\r\n            </main>\r\n\r\n            <NavDock activeTab={activeTab} onTabChange={(tab: Tab) => setActiveTab(tab)} />\r\n            {/* Badge Unlocked Overlay */}\r\n            <BadgeOverlay badge={newBadge} onClose={() => setNewBadge(null)} />\r\n        </div>\r\n    );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\user\\Desktop\\AG\\RB\\bible-app\\src\\components\\BibleProgressMap.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'SmartCard' is defined but never used.","line":9,"column":10,"nodeType":null,"messageId":"unusedVar","endLine":9,"endColumn":19}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"\r\n\"use client\";\r\n\r\nimport { BIBLE_BOOKS, BibleBook } from \"@/lib/bible-metadata\";\r\nimport { Check } from \"lucide-react\";\r\nimport { useState, useMemo } from \"react\";\r\nimport { cn } from \"@/lib/utils\";\r\nimport { ScrollArea } from \"@/components/ui/scroll-area\";\r\nimport { SmartCard } from \"@/components/ui/smart-card\";\r\n\r\ninterface BibleProgressMapProps {\r\n    completedVerses: string[];\r\n}\r\n\r\ninterface BibleBookWithProgress extends BibleBook {\r\n    percent: number;\r\n    isCompleted: boolean;\r\n}\r\n\r\nexport default function BibleProgressMap({ completedVerses }: BibleProgressMapProps) {\r\n    const [selectedBook, setSelectedBook] = useState<BibleBookWithProgress | null>(null);\r\n    const [activeTab, setActiveTab] = useState<'OT' | 'NT'>('OT');\r\n\r\n    // 1. Process completed verses into a Set of \"BookName ChapterNumber\"\r\n    // Handles ranges like \"李쎌꽭湲?1-3??" -> \"李쎌꽭湲?1\", \"李쎌꽭湲?2\", \"李쎌꽭湲?3\"\r\n    const completedChapterSet = useMemo(() => {\r\n        const set = new Set<string>();\r\n        completedVerses.forEach(v => {\r\n            const parts = v.trim().split(' ');\r\n            if (parts.length < 2) return;\r\n\r\n            const bookName = parts[0];\r\n            const chapterPart = parts[1].replace('??, ''); // \"1-3\" or \"1\"\r\n\r\n            if (chapterPart.includes('-')) {\r\n                const [start, end] = chapterPart.split('-').map(n => parseInt(n));\r\n                if (!isNaN(start) && !isNaN(end)) {\r\n                    for (let i = start; i <= end; i++) {\r\n                        set.add(`${bookName} ${i}`);\r\n                    }\r\n                }\r\n            } else {\r\n                const chapter = parseInt(chapterPart);\r\n                if (!isNaN(chapter)) {\r\n                    set.add(`${bookName} ${chapter}`);\r\n                }\r\n            }\r\n        });\r\n        return set;\r\n    }, [completedVerses]);\r\n\r\n    // Calculate progress for each book based on the detailed Set\r\n    const booksWithProgress = useMemo(() => {\r\n        return BIBLE_BOOKS.map(book => {\r\n            let completedCount = 0;\r\n            for (let i = 1; i <= book.chapters; i++) {\r\n                if (completedChapterSet.has(`${book.name} ${i}`)) {\r\n                    completedCount++;\r\n                }\r\n            }\r\n            const percent = (completedCount / book.chapters) * 100;\r\n            return { ...book, percent, isCompleted: percent === 100 };\r\n        });\r\n    }, [completedChapterSet]);\r\n\r\n    const currentBooks = useMemo(() => {\r\n        return booksWithProgress.filter(b => b.category === activeTab);\r\n    }, [booksWithProgress, activeTab]);\r\n\r\n    return (\r\n        <div className=\"flex flex-col h-full min-h-[400px]\">\r\n            {/* Tab Switcher */}\r\n            <div className=\"flex p-1 mb-4 bg-muted/30 rounded-lg\">\r\n                <button\r\n                    onClick={() => setActiveTab('OT')}\r\n                    className={cn(\r\n                        \"flex-1 py-1.5 text-xs font-bold rounded-md transition-all duration-300\",\r\n                        activeTab === 'OT'\r\n                            ? \"bg-background text-foreground shadow-sm\"\r\n                            : \"text-muted-foreground hover:text-foreground hover:bg-muted/50\"\r\n                    )}\r\n                >\r\n                    援ъ빟\r\n                </button>\r\n                <button\r\n                    onClick={() => setActiveTab('NT')}\r\n                    className={cn(\r\n                        \"flex-1 py-1.5 text-xs font-bold rounded-md transition-all duration-300\",\r\n                        activeTab === 'NT'\r\n                            ? \"bg-background text-foreground shadow-sm\"\r\n                            : \"text-muted-foreground hover:text-foreground hover:bg-muted/50\"\r\n                    )}\r\n                >\r\n                    ?좎빟\r\n                </button>\r\n            </div>\r\n\r\n            <ScrollArea className=\"flex-1 pr-4 -mr-4\">\r\n                <div className=\"grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 gap-3 pb-4\">\r\n                    {currentBooks.map((book) => (\r\n                        <button\r\n                            key={book.name}\r\n                            onClick={() => setSelectedBook(book)}\r\n                            className={cn(\r\n                                \"relative flex flex-col items-center justify-center p-3 rounded-xl border transition-all duration-300 group\",\r\n                                book.isCompleted\r\n                                    ? \"bg-primary/5 border-primary/20 hover:bg-primary/10\"\r\n                                    : \"bg-card hover:bg-muted border-border hover:border-primary/30\"\r\n                            )}\r\n                        >\r\n                            {/* Progress Circle / Status */}\r\n                            <div className=\"relative mb-2\">\r\n                                <div className={cn(\r\n                                    \"w-8 h-8 rounded-full flex items-center justify-center text-[10px] font-bold transition-colors\",\r\n                                    book.isCompleted\r\n                                        ? \"bg-primary text-primary-foreground\"\r\n                                        : book.percent > 0\r\n                                            ? \"bg-primary/10 text-primary\"\r\n                                            : \"bg-muted text-muted-foreground\"\r\n                                )}>\r\n                                    {book.isCompleted ? (\r\n                                        <Check size={14} strokeWidth={3} />\r\n                                    ) : (\r\n                                        <span>{Math.round(book.percent)}%</span>\r\n                                    )}\r\n                                </div>\r\n\r\n                                {/* Active Indicator Ring */}\r\n                                {book.percent > 0 && !book.isCompleted && (\r\n                                    <div className=\"absolute inset-0 rounded-full border-2 border-primary/30 animate-pulse\" />\r\n                                )}\r\n                            </div>\r\n\r\n                            {/* Book Name */}\r\n                            <span className={cn(\r\n                                \"text-xs font-serif font-semibold text-center leading-tight transition-colors font-scalable\",\r\n                                book.isCompleted ? \"text-primary font-bold\" : \"text-muted-foreground group-hover:text-foreground\"\r\n                            )}>\r\n                                {book.name}\r\n                            </span>\r\n                        </button>\r\n                    ))}\r\n                </div>\r\n            </ScrollArea>\r\n\r\n            {/* Chapter Detail Modal (Overlay) */}\r\n            {selectedBook && (\r\n                <div\r\n                    className=\"fixed inset-0 z-[100] flex items-center justify-center p-4 bg-background/80 backdrop-blur-sm animate-in fade-in duration-200\"\r\n                    onClick={(e) => {\r\n                        if (e.target === e.currentTarget) setSelectedBook(null);\r\n                    }}\r\n                >\r\n                    <div className=\"w-full max-w-sm bg-card border border-border/50 rounded-2xl shadow-2xl overflow-hidden flex flex-col max-h-[80vh]\">\r\n                        <div className=\"text-center p-4 border-b bg-muted/20 shrink-0\">\r\n                            <h3 className=\"text-xl font-serif font-bold text-foreground\">{selectedBook.name}</h3>\r\n                            <p className=\"text-xs text-muted-foreground uppercase tracking-widest mt-1\">\r\n                                {Math.round(selectedBook.percent)}% ?꾨즺 ({selectedBook.chapters}??以?\r\n                            </p>\r\n                        </div>\r\n\r\n                        {/* Native Scroll Container for reliability */}\r\n                        <div className=\"flex-1 overflow-y-auto p-4 min-h-0 overscroll-contain\">\r\n                            <div className=\"grid grid-cols-5 gap-2 pb-2\">\r\n                                {Array.from({ length: selectedBook.chapters }, (_, i) => i + 1).map(chapter => {\r\n                                    const isRead = completedChapterSet.has(`${selectedBook.name} ${chapter}`);\r\n                                    return (\r\n                                        <div\r\n                                            key={chapter}\r\n                                            className={cn(\r\n                                                \"aspect-square rounded-md flex items-center justify-center text-xs font-medium border transition-colors\",\r\n                                                isRead\r\n                                                    ? \"bg-primary text-primary-foreground border-primary\"\r\n                                                    : \"bg-muted/30 text-muted-foreground border-transparent\"\r\n                                            )}\r\n                                        >\r\n                                            {chapter}\r\n                                        </div>\r\n                                    );\r\n                                })}\r\n                            </div>\r\n                        </div>\r\n\r\n                        <div className=\"p-4 border-t bg-muted/20 shrink-0\">\r\n                            <button\r\n                                onClick={() => setSelectedBook(null)}\r\n                                className=\"w-full py-3 bg-secondary hover:bg-muted rounded-xl text-xs font-bold uppercase tracking-widest transition-colors\"\r\n                            >\r\n                                ?リ린\r\n                            </button>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            )}\r\n        </div>\r\n    );\r\n}\r\n\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\user\\Desktop\\AG\\RB\\bible-app\\src\\components\\ChurchLogo.tsx","messages":[{"ruleId":"@next/next/no-img-element","severity":1,"message":"Using `<img>` could result in slower LCP and higher bandwidth. Consider using `<Image />` from `next/image` or a custom image loader to automatically optimize images. This may incur additional usage or cost from your provider. See: https://nextjs.org/docs/messages/no-img-element","line":18,"column":25,"nodeType":"JSXOpeningElement","endLine":26,"endColumn":27}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"\"use client\";\r\n\r\nimport { useState } from \"react\";\r\n\r\nexport default function ChurchLogo() {\r\n    const [isError, setIsError] = useState(false);\r\n\r\n    return (\r\n        <div className=\"flex justify-center items-center py-4\">\r\n            <div className=\"flex items-center justify-center transition-all duration-500 hover:scale-105\">\r\n                {!isError ? (\r\n                    <a\r\n                        href=\"http://mokposarang.org/\"\r\n                        target=\"_blank\"\r\n                        rel=\"noopener noreferrer\"\r\n                        className=\"relative flex items-center justify-center group cursor-pointer\"\r\n                    >\r\n                        <img\r\n                            src=\"/logo-final.png?v=11\"\r\n                            alt=\"?щ옉?섍탳??"\r\n                            className=\"h-11 w-auto object-contain transition-opacity group-hover:opacity-80 drop-shadow-sm\"\r\n                            style={{\r\n                                filter: 'brightness(0) saturate(100%) invert(20%) sepia(85%) saturate(3000%) hue-rotate(345deg) brightness(95%) contrast(100%)' // Forces red color via CSS filter\r\n                            }}\r\n                            onError={() => setIsError(true)}\r\n                        />\r\n                    </a>\r\n                ) : (\r\n                    <a\r\n                        href=\"http://mokposarang.org/\"\r\n                        target=\"_blank\"\r\n                        rel=\"noopener noreferrer\"\r\n                        className=\"text-red-600 font-bold text-sm tracking-tight hover:opacity-10 transition-opacity cursor-pointer\"\r\n                    >\r\n                        ?щ옉?섍탳??r\n                    </a>\r\n                )}\r\n            </div>\r\n        </div>\r\n    );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\user\\Desktop\\AG\\RB\\bible-app\\src\\components\\DateNavigator.tsx","messages":[{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\nC:\\Users\\user\\Desktop\\AG\\RB\\bible-app\\src\\components\\DateNavigator.tsx:29:13\n  27 |     useEffect(() => {\n  28 |         if (isPickerOpen) {\n> 29 |             setPickerDate(new Date(currentDate));\n     |             ^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  30 |             setPickerView('month');\n  31 |         }\n  32 |     }, [isPickerOpen, currentDate]);","line":29,"column":13,"nodeType":null,"endLine":29,"endColumn":26},{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\nC:\\Users\\user\\Desktop\\AG\\RB\\bible-app\\src\\components\\DateNavigator.tsx:96:9\n  94 |     const [today, setToday] = useState<Date | null>(null);\n  95 |     useEffect(() => {\n> 96 |         setToday(new Date());\n     |         ^^^^^^^^ Avoid calling setState() directly within an effect\n  97 |     }, []);\n  98 |\n  99 |     // Scroll drag logic","line":96,"column":9,"nodeType":null,"endLine":96,"endColumn":17}],"suppressedMessages":[],"errorCount":2,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"\"use client\";\r\n\r\nimport { useRouter } from \"next/navigation\";\r\nimport { format, addDays, subDays, eachDayOfInterval, isSameDay, addMonths, subMonths } from \"date-fns\";\r\nimport { ko } from \"date-fns/locale\";\r\nimport { useState, useRef, useEffect } from \"react\";\r\nimport { cn } from \"@/lib/utils\";\r\nimport { ChevronLeft, ChevronRight, ChevronsLeft, ChevronsRight, X } from \"lucide-react\";\r\nimport { SmartCard } from \"@/components/ui/smart-card\";\r\n\r\ninterface DateNavigatorProps {\r\n    currentDate: string;\r\n    onDateChange?: (date: string) => void;\r\n}\r\n\r\nexport default function DateNavigator({ currentDate, onDateChange }: DateNavigatorProps) {\r\n    const router = useRouter();\r\n    const dateObj = new Date(currentDate);\r\n    const scrollRef = useRef<HTMLDivElement>(null);\r\n\r\n    // Date Picker State\r\n    const [isPickerOpen, setIsPickerOpen] = useState(false);\r\n    const [pickerView, setPickerView] = useState<'month' | 'day'>('month');\r\n    const [pickerDate, setPickerDate] = useState<Date>(new Date(currentDate));\r\n\r\n    // Sync picker date when opening\r\n    useEffect(() => {\r\n        if (isPickerOpen) {\r\n            setPickerDate(new Date(currentDate));\r\n            setPickerView('month');\r\n        }\r\n    }, [isPickerOpen, currentDate]);\r\n\r\n    const navigateTo = (date: Date) => {\r\n        const dateStr = format(date, \"yyyy-MM-dd\");\r\n        if (typeof navigator !== \"undefined\" && navigator.vibrate) {\r\n            navigator.vibrate(10);\r\n        }\r\n        if (onDateChange) {\r\n            onDateChange(dateStr);\r\n        } else {\r\n            router.push(`?date=${dateStr}`);\r\n        }\r\n    };\r\n\r\n    const handleYearChange = (amount: number) => {\r\n        setPickerDate(prev => addMonths(prev, amount * 12));\r\n    };\r\n\r\n    const handleMonthSelect = (monthIndex: number) => {\r\n        const newDate = new Date(pickerDate);\r\n        newDate.setMonth(monthIndex);\r\n        setPickerDate(newDate);\r\n        setPickerView('day');\r\n    };\r\n\r\n    const handleDaySelect = (day: Date) => {\r\n        navigateTo(day);\r\n        setIsPickerOpen(false);\r\n    };\r\n\r\n    const handlePrevMonth = () => navigateTo(subMonths(dateObj, 1));\r\n    const handleNextMonth = () => navigateTo(addMonths(dateObj, 1));\r\n    const handlePrevDay = () => navigateTo(subDays(dateObj, 1));\r\n    const handleNextDay = () => navigateTo(addDays(dateObj, 1));\r\n\r\n    // Generate days for picker calendar view\r\n    const pickerMonthStart = new Date(pickerDate.getFullYear(), pickerDate.getMonth(), 1);\r\n    const pickerMonthEnd = addMonths(pickerMonthStart, 1);\r\n    const pickerDays = eachDayOfInterval({\r\n        start: pickerMonthStart,\r\n        end: subDays(pickerMonthEnd, 1)\r\n    });\r\n\r\n    const startDayOfWeek = parseInt(format(pickerMonthStart, \"i\"));\r\n    const paddingDays = startDayOfWeek === 7 ? 0 : startDayOfWeek;\r\n\r\n    // Generate horizontal scroll days\r\n    const startDate = subDays(dateObj, 14);\r\n    const endDate = addDays(dateObj, 14);\r\n    const days = eachDayOfInterval({ start: startDate, end: endDate });\r\n\r\n    // Auto-scroll effect\r\n    useEffect(() => {\r\n        if (scrollRef.current) {\r\n            const selectedElement = scrollRef.current.querySelector('[data-selected=\"true\"]');\r\n            if (selectedElement) {\r\n                selectedElement.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });\r\n            }\r\n        }\r\n    }, [currentDate]);\r\n\r\n    // Hydration fix\r\n    const [today, setToday] = useState<Date | null>(null);\r\n    useEffect(() => {\r\n        setToday(new Date());\r\n    }, []);\r\n\r\n    // Scroll drag logic\r\n    const [isDragging, setIsDragging] = useState(false);\r\n    const [startX, setStartX] = useState(0);\r\n    const [scrollLeft, setScrollLeft] = useState(0);\r\n\r\n    const handleMouseDown = (e: React.MouseEvent) => {\r\n        if (!scrollRef.current) return;\r\n        setIsDragging(true);\r\n        setStartX(e.pageX - scrollRef.current.offsetLeft);\r\n        setScrollLeft(scrollRef.current.scrollLeft);\r\n    };\r\n\r\n    const handleMouseLeave = () => setIsDragging(false);\r\n    const handleMouseUp = () => setIsDragging(false);\r\n    const handleMouseMove = (e: React.MouseEvent) => {\r\n        if (!isDragging || !scrollRef.current) return;\r\n        e.preventDefault();\r\n        const x = e.pageX - scrollRef.current.offsetLeft;\r\n        const walk = (x - startX) * 2;\r\n        scrollRef.current.scrollLeft = scrollLeft - walk;\r\n    };\r\n\r\n    return (\r\n        <div className=\"flex flex-col gap-2 relative\">\r\n            {/* Modal Overlay */}\r\n            {isPickerOpen && (\r\n                <div className=\"fixed inset-0 z-50 flex items-center justify-center bg-background/60 backdrop-blur-sm animate-in fade-in duration-200\">\r\n                    <SmartCard variant=\"elevated\" className=\"w-[320px] p-0 overflow-hidden shadow-2xl border-primary/20\">\r\n                        {/* Picker Header */}\r\n                        <div className=\"bg-muted/50 p-4 flex items-center justify-between border-b\">\r\n                            {pickerView === 'month' ? (\r\n                                <div className=\"flex items-center justify-between w-full\">\r\n                                    <button onClick={() => handleYearChange(-1)} className=\"p-1 hover:bg-background rounded-full\"><ChevronLeft size={16} /></button>\r\n                                    <span className=\"font-serif font-bold text-lg\">{format(pickerDate, \"yyyy??")}</span>\r\n                                    <button onClick={() => handleYearChange(1)} className=\"p-1 hover:bg-background rounded-full\"><ChevronRight size={16} /></button>\r\n                                </div>\r\n                            ) : (\r\n                                <div className=\"flex items-center gap-2\">\r\n                                    <button onClick={() => setPickerView('month')} className=\"p-1 hover:bg-background rounded-full\"><ChevronLeft size={16} /></button>\r\n                                    <span className=\"font-serif font-bold text-lg\">{format(pickerDate, \"yyyy??M??")}</span>\r\n                                </div>\r\n                            )}\r\n                            <button onClick={() => setIsPickerOpen(false)} className=\"ml-2 p-1 hover:bg-destructive/10 hover:text-destructive rounded-full\">\r\n                                <X size={16} />\r\n                            </button>\r\n                        </div>\r\n\r\n                        {/* Picker Body */}\r\n                        <div className=\"p-4\">\r\n                            {pickerView === 'month' ? (\r\n                                <div className=\"grid grid-cols-3 gap-3\">\r\n                                    {Array.from({ length: 12 }).map((_, i) => (\r\n                                        <button\r\n                                            key={i}\r\n                                            onClick={() => handleMonthSelect(i)}\r\n                                            className={cn(\r\n                                                \"py-3 rounded-lg text-sm font-medium transition-colors border\",\r\n                                                i === pickerDate.getMonth()\r\n                                                    ? \"bg-primary text-primary-foreground border-primary\"\r\n                                                    : \"hover:bg-muted border-transparent hover:border-border\"\r\n                                            )}\r\n                                        >\r\n                                            {i + 1}??r\n                                        </button>\r\n                                    ))}\r\n                                </div>\r\n                            ) : (\r\n                                <div>\r\n                                    {/* Days Header */}\r\n                                    <div className=\"grid grid-cols-7 mb-2 text-center\">\r\n                                        {['??, '??, '??, '??, '紐?, '湲?, '??].map(d => (\r\n                                            <span key={d} className=\"text-[10px] text-muted-foreground font-bold\">{d}</span>\r\n                                        ))}\r\n                                    </div>\r\n                                    {/* Calendar Grid */}\r\n                                    <div className=\"grid grid-cols-7 gap-1\">\r\n                                        {/* Padding */}\r\n                                        {Array.from({ length: paddingDays }).map((_, i) => (\r\n                                            <div key={`pad-${i}`} />\r\n                                        ))}\r\n                                        {/* Days */}\r\n                                        {pickerDays.map(day => {\r\n                                            const isSelected = isSameDay(day, dateObj);\r\n                                            return (\r\n                                                <button\r\n                                                    key={day.toISOString()}\r\n                                                    onClick={() => handleDaySelect(day)}\r\n                                                    className={cn(\r\n                                                        \"h-9 w-full rounded-md flex items-center justify-center text-sm transition-all\",\r\n                                                        isSelected\r\n                                                            ? \"bg-primary text-primary-foreground font-bold shadow-sm\"\r\n                                                            : \"hover:bg-muted text-foreground\"\r\n                                                    )}\r\n                                                >\r\n                                                    {format(day, \"d\")}\r\n                                                </button>\r\n                                            )\r\n                                        })}\r\n                                    </div>\r\n                                </div>\r\n                            )}\r\n                        </div>\r\n                    </SmartCard>\r\n                </div>\r\n            )}\r\n\r\n            {/* Navigation Header */}\r\n            <div className=\"flex items-center justify-between px-2\">\r\n                <div className=\"flex items-center gap-1\">\r\n                    <button\r\n                        onClick={handlePrevMonth}\r\n                        className=\"p-2 rounded-full hover:bg-muted/50 transition-colors text-muted-foreground hover:text-foreground\"\r\n                        aria-label=\"?댁쟾 ??"\r\n                    >\r\n                        <ChevronsLeft size={20} />\r\n                    </button>\r\n                    <button\r\n                        onClick={handlePrevDay}\r\n                        className=\"p-2 rounded-full hover:bg-muted/50 transition-colors text-muted-foreground hover:text-foreground\"\r\n                        aria-label=\"?댁쟾 ??"\r\n                    >\r\n                        <ChevronLeft size={20} />\r\n                    </button>\r\n                </div>\r\n\r\n                <button\r\n                    onClick={() => setIsPickerOpen(true)}\r\n                    className=\"text-lg font-bold tracking-tight text-foreground font-serif hover:text-primary transition-colors px-2 py-1 rounded-md hover:bg-muted/50\"\r\n                >\r\n                    {format(dateObj, \"yyyy??M??d??")}\r\n                </button>\r\n\r\n                <div className=\"flex items-center gap-1\">\r\n                    <button\r\n                        onClick={handleNextDay}\r\n                        className=\"p-2 rounded-full hover:bg-muted/50 transition-colors text-muted-foreground hover:text-foreground\"\r\n                        aria-label=\"?ㅼ쓬 ??"\r\n                    >\r\n                        <ChevronRight size={20} />\r\n                    </button>\r\n                    <button\r\n                        onClick={handleNextMonth}\r\n                        className=\"p-2 rounded-full hover:bg-muted/50 transition-colors text-muted-foreground hover:text-foreground\"\r\n                        aria-label=\"?ㅼ쓬 ??"\r\n                    >\r\n                        <ChevronsRight size={20} />\r\n                    </button>\r\n                </div>\r\n            </div>\r\n\r\n            <div className=\"relative w-full -mx-4 md:mx-0 px-4 md:px-0\">\r\n                {/* Fade Gradients */}\r\n                <div className=\"absolute left-0 top-0 bottom-0 w-12 bg-gradient-to-r from-background to-transparent z-10 pointer-events-none\" />\r\n                <div className=\"absolute right-0 top-0 bottom-0 w-12 bg-gradient-to-l from-background to-transparent z-10 pointer-events-none\" />\r\n\r\n                <div\r\n                    ref={scrollRef}\r\n                    className={cn(\r\n                        \"flex items-center gap-3 overflow-x-auto no-scrollbar py-2 px-6 snap-x snap-mandatory touch-pan-x\",\r\n                        isDragging ? \"cursor-grabbing snap-none\" : \"cursor-grab\"\r\n                    )}\r\n                    onMouseDown={handleMouseDown}\r\n                    onMouseLeave={handleMouseLeave}\r\n                    onMouseUp={handleMouseUp}\r\n                    onMouseMove={handleMouseMove}\r\n                >\r\n                    {days.map((day) => {\r\n                        const isSelected = isSameDay(day, dateObj);\r\n                        const isToday = today && isSameDay(day, today);\r\n\r\n                        return (\r\n                            <button\r\n                                key={day.toISOString()}\r\n                                onClick={() => navigateTo(day)}\r\n                                data-selected={isSelected}\r\n                                className={cn(\r\n                                    \"relative shrink-0 flex flex-col items-center justify-center w-14 h-20 rounded-2xl transition-all duration-300 snap-center group border\",\r\n                                    isSelected\r\n                                        ? \"bg-primary text-primary-foreground border-primary shadow-lg shadow-primary/25 scale-105 z-10\"\r\n                                        : \"bg-card hover:bg-muted border-border text-muted-foreground hover:scale-105\"\r\n                                )}\r\n                            >\r\n\r\n                                <span className={cn(\r\n                                    \"text-[10px] uppercase font-bold tracking-wider mb-1\",\r\n                                    isSelected ? \"text-primary-foreground/70\" : \"text-muted-foreground/70\"\r\n                                )}>\r\n                                    {format(day, \"E\", { locale: ko })}\r\n                                </span>\r\n                                <span className={cn(\r\n                                    \"text-2xl font-display font-bold\",\r\n                                    isSelected ? \"text-primary-foreground\" : \"text-foreground\"\r\n                                )}>\r\n                                    {format(day, \"d\")}\r\n                                </span>\r\n\r\n                                {isToday && !isSelected && (\r\n                                    <div className=\"absolute bottom-2 w-1 h-1 rounded-full bg-primary\" />\r\n                                )}\r\n                            </button>\r\n                        );\r\n                    })}\r\n                </div>\r\n            </div>\r\n        </div>\r\n    );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\user\\Desktop\\AG\\RB\\bible-app\\src\\components\\GroupChallengeView.tsx","messages":[{"ruleId":"@typescript-eslint/ban-ts-comment","severity":2,"message":"Use \"@ts-expect-error\" instead of \"@ts-ignore\", as \"@ts-ignore\" will do nothing if the following line is error-free.","line":154,"column":17,"nodeType":"Line","messageId":"tsIgnoreInsteadOfExpectError","endLine":154,"endColumn":63,"suggestions":[{"messageId":"replaceTsIgnoreWithTsExpectError","fix":{"range":[5339,5385],"text":"// @ts-expect-error - Supabase types are tricky here"},"desc":"Replace \"@ts-ignore\" with \"@ts-expect-error\"."}]}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"\"use client\";\r\n\r\nimport { useState, useEffect } from \"react\";\r\nimport { SmartCard } from \"./ui/smart-card\";\r\nimport { Users, UserPlus, Trophy, Flame, MessageCircle, Send, Zap } from \"lucide-react\";\r\nimport { cn } from \"@/lib/utils\";\r\nimport { createClient } from \"@/lib/supabase-client\";\r\nimport { User } from \"@supabase/supabase-js\";\r\n\r\ninterface GroupMember {\r\n    id: string;\r\n    email: string;\r\n    name: string;\r\n    streak: number;\r\n    progress: number;\r\n    lastActive: string;\r\n    isOnline: boolean;\r\n}\r\n\r\ninterface Presence {\r\n    name: string;\r\n    online_at?: string;\r\n    streak?: number;\r\n    progress?: number;\r\n}\r\n\r\ninterface BroadcastPayload {\r\n    memberName?: string;\r\n    userName?: string;\r\n    type?: string;\r\n    text?: string;\r\n    from?: string;\r\n    to?: string;\r\n    emoji?: string;\r\n}\r\n\r\ninterface GroupChallengeViewProps {\r\n    user: User | null;\r\n    streak: number;\r\n    progress: number;\r\n}\r\n\r\nexport default function GroupChallengeView({ user, streak, progress }: GroupChallengeViewProps) {\r\n    const [groupId, setGroupId] = useState<string | null>(null);\r\n    const [inviteCode, setInviteCode] = useState(\"\");\r\n    const [members, setMembers] = useState<GroupMember[]>([]);\r\n    const [messages, setMessages] = useState<{ user: string, text: string }[]>([]);\r\n    const [presenceState, setPresenceState] = useState<Record<string, Presence[]>>({});\r\n    const [isConnected, setIsConnected] = useState(false);\r\n    const [newMessage, setNewMessage] = useState(\"\");\r\n    const [pokeNotification, setPokeNotification] = useState<{ from: string, emoji: string } | null>(null);\r\n    const supabase = createClient();\r\n\r\n    // Load group from local storage or DB\r\n    useEffect(() => {\r\n        const savedGroup = localStorage.getItem('bible_group_id');\r\n        if (savedGroup) setGroupId(savedGroup);\r\n    }, []);\r\n\r\n    // Load messages for current group\r\n    useEffect(() => {\r\n        if (!groupId) return;\r\n        const saved = localStorage.getItem(`bible_group_messages_${groupId}`);\r\n        if (saved) {\r\n            try {\r\n                setMessages(JSON.parse(saved));\r\n            } catch (e) {\r\n                console.error(\"Failed to load messages\", e);\r\n            }\r\n        } else {\r\n            setMessages([]);\r\n        }\r\n    }, [groupId]);\r\n\r\n    // Save messages whenever they change\r\n    useEffect(() => {\r\n        if (!groupId) return;\r\n        if (messages.length > 0) {\r\n            localStorage.setItem(`bible_group_messages_${groupId}`, JSON.stringify(messages));\r\n        }\r\n    }, [messages, groupId]);\r\n\r\n    // Sync Members from Chat History and Presence\r\n    useEffect(() => {\r\n        const uniqueUsers = new Set<string>();\r\n        // 1. Get users from chat history\r\n        messages.forEach(msg => {\r\n            if (msg.user !== 'System') uniqueUsers.add(msg.user);\r\n        });\r\n\r\n        // 2. Get users from Presence State\r\n        Object.values(presenceState).forEach((presences: unknown) => {\r\n            if (Array.isArray(presences)) {\r\n                presences.forEach((p: Presence) => {\r\n                    if (p.name) uniqueUsers.add(p.name);\r\n                });\r\n            }\r\n        });\r\n\r\n        // 3. Current User\r\n        if (user) {\r\n            uniqueUsers.add(user.email?.split('@')[0] || '??);\r\n        }\r\n\r\n        const updatedMembers = Array.from(uniqueUsers).map(userName => {\r\n            // Check if user is in presence state (Online)\r\n            let isOnline = false;\r\n            let lastActive = new Date().toISOString(); // Default to now if online, or fallback\r\n\r\n            // Check presence for online status\r\n            const onlinePresence = Object.values(presenceState).flat().find((p) => p.name === userName);\r\n            if (onlinePresence) {\r\n                isOnline = true;\r\n                lastActive = onlinePresence.online_at || new Date().toISOString();\r\n            }\r\n\r\n            // Use data from presence if available, otherwise fallback/placeholder\r\n            const memberStreak = onlinePresence?.streak ?? (userName === (user?.email?.split('@')[0] || '??) ? streak : Math.floor(Math.random() * 20));\r\n            const memberProgress = onlinePresence?.progress ?? (userName === (user?.email?.split('@')[0] || '??) ? progress : Math.floor(Math.random() * 100));\r\n\r\n            return {\r\n                id: userName, // Using name as ID for now since auth ID is not available for all\r\n                email: \"\",\r\n                name: userName,\r\n                streak: memberStreak,\r\n                progress: memberProgress,\r\n                lastActive: lastActive,\r\n                isOnline: isOnline\r\n            };\r\n        });\r\n\r\n        // Sort: Online first, then by Name\r\n        updatedMembers.sort((a, b) => {\r\n            if (a.isOnline === b.isOnline) return a.name.localeCompare(b.name);\r\n            return a.isOnline ? -1 : 1;\r\n        });\r\n\r\n        setMembers(updatedMembers);\r\n\r\n    }, [messages, presenceState, user, streak, progress]);\r\n\r\n    // Supabase Realtime Sync\r\n    useEffect(() => {\r\n        if (!groupId || !user) return;\r\n\r\n        const channel = supabase.channel(`group-${groupId}`, {\r\n            config: {\r\n                presence: { key: user.id }\r\n            }\r\n        });\r\n\r\n        channel\r\n            .on('presence', { event: 'sync' }, () => {\r\n                // @ts-ignore - Supabase types are tricky here\r\n                setPresenceState(channel.presenceState() as unknown as Record<string, Presence[]>);\r\n            })\r\n            .on('broadcast', { event: 'activity' }, (payload: BroadcastPayload) => {\r\n                const { memberName, type } = payload;\r\n                const msg = type === 'complete'\r\n                    ? `${memberName}?섏씠 ?ㅻ뒛??留먯????꾨룆?덉뒿?덈떎! ?럦`\r\n                    : `${memberName}?섏씠 ?깃꼍 ?쎄린瑜??쒖옉?덉뒿?덈떎. ?뱰`;\r\n                setMessages(prev => [{ user: 'System', text: msg }, ...prev].slice(0, 50));\r\n            })\r\n            .on('broadcast', { event: 'chat' }, (payload: BroadcastPayload) => {\r\n                setMessages(prev => [{ user: payload.userName || '?듬챸', text: payload.text || '' }, ...prev].slice(0, 50));\r\n            })\r\n            .on('broadcast', { event: 'poke' }, (payload: BroadcastPayload) => {\r\n                const { from, to, emoji } = payload;\r\n                const myName = user.email?.split('@')[0] || '??;\r\n                // Only show notification if I am the target\r\n                if (to === myName && from && emoji) {\r\n                    setPokeNotification({ from, emoji });\r\n                    setTimeout(() => setPokeNotification(null), 3000);\r\n                }\r\n            })\r\n            .subscribe(async (status: 'SUBSCRIBED' | 'TIMED_OUT' | 'POSTGRES_CHANGES_FAILURE' | 'CHANNEL_ERROR' | 'CLOSED') => {\r\n                if (status === 'SUBSCRIBED') {\r\n                    setIsConnected(true);\r\n                    await channel.track({\r\n                        id: user.id,\r\n                        name: user.email?.split('@')[0] || '?듬챸',\r\n                        online_at: new Date().toISOString(),\r\n                        streak: streak,\r\n                        progress: progress\r\n                    });\r\n                } else if (status === 'CLOSED' || status === 'CHANNEL_ERROR') {\r\n                    setIsConnected(false);\r\n                }\r\n            });\r\n\r\n\r\n        return () => {\r\n            supabase.removeChannel(channel);\r\n            setIsConnected(false);\r\n        };\r\n    }, [groupId, user, streak, progress, supabase]);\r\n\r\n    const handleJoinGroup = () => {\r\n        if (inviteCode.trim()) {\r\n            setGroupId(inviteCode);\r\n            localStorage.setItem('bible_group_id', inviteCode);\r\n        }\r\n    };\r\n\r\n    const sendMessage = () => {\r\n        if (!newMessage.trim() || !groupId) return;\r\n\r\n        supabase.channel(`group-${groupId}`).send({\r\n            type: 'broadcast',\r\n            event: 'chat',\r\n            payload: { userName: user?.email?.split('@')[0] || '?듬챸', text: newMessage }\r\n        });\r\n\r\n        setNewMessage(\"\");\r\n    };\r\n\r\n    const handlePoke = (targetName: string) => {\r\n        if (!groupId || !user) return;\r\n        const myName = user.email?.split('@')[0] || '?듬챸';\r\n\r\n        supabase.channel(`group-${groupId}`).send({\r\n            type: 'broadcast',\r\n            event: 'poke',\r\n            payload: { from: myName, to: targetName, emoji: \"?솋\" }\r\n        });\r\n\r\n        // Optional: Local feedback or toast could be added here\r\n    };\r\n\r\n    if (!groupId) {\r\n        return (\r\n            <div className=\"space-y-6 py-4 animate-in fade-in duration-700\">\r\n                <SmartCard variant=\"elevated\" className=\"bg-gradient-to-br from-primary/10 to-accent/5 border-primary/20 p-8 text-center\">\r\n                    <div className=\"w-20 h-20 rounded-full bg-primary/20 flex items-center justify-center mx-auto mb-6\">\r\n                        <Users size={40} className=\"text-primary\" />\r\n                    </div>\r\n                    <h2 className=\"text-2xl font-serif font-black mb-2\">怨듬룞泥댁? ?④퍡 ?쎄린</h2>\r\n                    <p className=\"text-sm text-muted-foreground mb-8\">媛議? 援먰쉶 ?뚭렇猷?硫ㅻ쾭?ㅺ낵 ?④퍡 ?쎌쑝硫?br />?쒕줈 寃⑸젮?섍퀬 吏꾪뻾瑜좎쓣 怨듭쑀?대낫?몄슂.</p>\r\n\r\n                    <div className=\"space-y-3\">\r\n                        <input\r\n                            type=\"text\"\r\n                            placeholder=\"珥덈? 肄붾뱶 ?낅젰 (?? MYCHURCH)\"\r\n                            value={inviteCode}\r\n                            onChange={(e) => setInviteCode(e.target.value.toUpperCase())}\r\n                            className=\"w-full bg-background border border-border rounded-2xl px-4 py-4 text-center font-bold tracking-widest outline-none focus:border-primary transition-all\"\r\n                        />\r\n                        <button\r\n                            onClick={handleJoinGroup}\r\n                            className=\"w-full py-4 rounded-2xl bg-primary text-primary-foreground font-bold shadow-lg shadow-primary/20 active:scale-95 transition-all\"\r\n                        >\r\n                            洹몃９ 李몄뿬?섍린\r\n                        </button>\r\n                    </div>\r\n                </SmartCard>\r\n\r\n                <div className=\"flex items-center gap-4 py-2\">\r\n                    <div className=\"flex-1 h-px bg-border/50\" />\r\n                    <span className=\"text-[10px] uppercase tracking-widest font-bold text-muted-foreground/50\">OR</span>\r\n                    <div className=\"flex-1 h-px bg-border/50\" />\r\n                </div>\r\n\r\n                <button className=\"w-full py-3 rounded-2xl border border-dashed border-border text-xs font-bold text-muted-foreground hover:bg-muted/30 transition-all flex items-center justify-center gap-2\">\r\n                    <UserPlus size={14} />\r\n                    ?덈줈??梨뚮┛吏 洹몃９ 留뚮뱾湲?r\n                </button>\r\n            </div>\r\n        );\r\n    }\r\n\r\n    return (\r\n        <div className=\"space-y-4 py-2 animate-in slide-in-from-bottom-4 duration-700\">\r\n            <div className=\"flex items-center justify-between px-1\">\r\n                <div className=\"flex items-center gap-2\">\r\n                    <div className=\"px-2 py-1 bg-primary/10 text-primary text-[10px] font-black rounded-lg uppercase tracking-tighter\">Group Challenge</div>\r\n                    <div className=\"flex flex-col\">\r\n                        <h2 className=\"text-lg font-black leading-none\">{groupId}</h2>\r\n                        <button\r\n                            onClick={() => {\r\n                                if (groupId) {\r\n                                    const text = `[?깃꼍 365] ?④퍡 ?쎄린??珥덈??⑸땲?? ?뱰\\n\\n珥덈? 肄붾뱶: ${groupId}\\n\\n?깆뿉??肄붾뱶瑜??낅젰?섍퀬 李몄뿬?대낫?몄슂.`;\r\n                                    navigator.clipboard.writeText(text);