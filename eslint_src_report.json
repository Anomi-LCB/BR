messageId":"replaceWithAlt","data":{"alt":"&quot;"},"fix":{"range":[49346,49420],"text":"\r\n                    \"紐⑤뱺 ?깃꼍? ?섎굹?섏쓽 媛먮룞?쇰줈 ??寃껋쑝濡?quot; ???ㅽ썑 3:16\r\n                "},"desc":"Replace with `&quot;`."},{"messageId":"replaceWithAlt","data":{"alt":"&ldquo;"},"fix":{"range":[49346,49420],"text":"\r\n                    \"紐⑤뱺 ?깃꼍? ?섎굹?섏쓽 媛먮룞?쇰줈 ??寃껋쑝濡?ldquo; ???ㅽ썑 3:16\r\n                "},"desc":"Replace with `&ldquo;`."},{"messageId":"replaceWithAlt","data":{"alt":"&#34;"},"fix":{"range":[49346,49420],"text":"\r\n                    \"紐⑤뱺 ?깃꼍? ?섎굹?섏쓽 媛먮룞?쇰줈 ??寃껋쑝濡?#34; ???ㅽ썑 3:16\r\n                "},"desc":"Replace with `&#34;`."},{"messageId":"replaceWithAlt","data":{"alt":"&rdquo;"},"fix":{"range":[49346,49420],"text":"\r\n                    \"紐⑤뱺 ?깃꼍? ?섎굹?섏쓽 媛먮룞?쇰줈 ??寃껋쑝濡?rdquo; ???ㅽ썑 3:16\r\n                "},"desc":"Replace with `&rdquo;`."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":953,"column":11,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":953,"endColumn":14,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[50450,50453],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[50450,50453],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":6,"fatalErrorCount":0,"warningCount":6,"fixableErrorCount":0,"fixableWarningCount":0,"source":"\"use client\";\r\n\r\nimport { useState, useMemo, useEffect, useCallback } from \"react\";\r\nimport {\r\n    Moon, Sun, Trash2, Download, Upload, BookOpen,\r\n    ChevronRight, Youtube, Clock, Type,\r\n    Bell, BellOff, Share2, Award, Heart, Sparkles,\r\n    Volume2, VolumeX, Settings as SettingsIcon, AlertTriangle, FileJson,\r\n    Calendar as CalendarIcon, Repeat\r\n} from \"lucide-react\";\r\nimport { useTheme } from \"next-themes\";\r\nimport { SmartCard } from \"@/components/ui/smart-card\";\r\nimport { cn } from \"@/lib/utils\";\r\nimport {\r\n    loadNotificationSettings,\r\n    saveNotificationSettings,\r\n    scheduleDailyNotifications,\r\n    cancelAllDailyNotifications,\r\n    NotificationSettings,\r\n    DEFAULT_SETTINGS,\r\n} from \"@/lib/notification-service\";\r\nimport {\r\n    loadShareSettings,\r\n    saveShareSettings,\r\n    scheduleShareReminder,\r\n    cancelShareReminders,\r\n    shareContent,\r\n    shareViaSMS,\r\n    shareViaKakao,\r\n    ShareSettings,\r\n    DEFAULT_SHARE_SETTINGS,\r\n    ShareFrequency,\r\n    ShareChannel\r\n} from \"@/lib/share-service\";\r\nimport WidgetPreview from \"./WidgetPreview\";\r\nimport { BibleReadingPlan, UserProgress } from \"@/types/bible\";\r\nimport { MessageSquare, Phone } from \"lucide-react\";\r\n\r\n// --- Toggle Switch ---\r\nfunction ToggleSwitch({ checked, onCheckedChange, showIcon = false }: { checked: boolean; onCheckedChange: (c: boolean) => void; showIcon?: boolean }) {\r\n    return (\r\n        <button\r\n            onClick={() => onCheckedChange(!checked)}\r\n            className={cn(\r\n                \"w-12 h-7 rounded-full transition-all duration-300 relative shadow-inner\",\r\n                checked\r\n                    ? \"bg-gradient-to-r from-primary to-primary/80\"\r\n                    : \"bg-muted dark:bg-muted/50\"\r\n            )}\r\n        >\r\n            <div className={cn(\r\n                \"absolute top-0.5 w-6 h-6 rounded-full bg-white shadow-md transition-all duration-300 flex items-center justify-center\",\r\n                checked ? \"left-[22px]\" : \"left-0.5\"\r\n            )}>\r\n                {showIcon && (checked ? <Sun size={12} className=\"text-primary\" /> : <Moon size={12} className=\"text-muted-foreground\" />)}\r\n            </div>\r\n        </button>\r\n    );\r\n}\r\n\r\n// --- Option Selector ---\r\nfunction OptionSelector({ options, value, onChange }: {\r\n    options: { id: string; label: string; icon?: React.ReactNode }[];\r\n    value: string;\r\n    onChange: (v: string) => void;\r\n}) {\r\n    return (\r\n        <div className=\"flex gap-1.5 p-1 bg-muted/30 rounded-xl\">\r\n            {options.map(opt => (\r\n                <button\r\n                    key={opt.id}\r\n                    onClick={() => onChange(opt.id)}\r\n                    className={cn(\r\n                        \"flex-1 flex items-center justify-center gap-1.5 px-3 py-2 rounded-lg text-xs font-bold transition-all duration-300\",\r\n                        value === opt.id\r\n                            ? \"bg-primary text-primary-foreground shadow-sm\"\r\n                            : \"text-muted-foreground hover:text-foreground hover:bg-muted/50\"\r\n                    )}\r\n                >\r\n                    {opt.icon}\r\n                    {opt.label}\r\n                </button>\r\n            ))}\r\n        </div>\r\n    );\r\n}\r\n\r\ninterface SettingsViewProps {\r\n    onReschedule?: () => void;\r\n    progress?: UserProgress[];\r\n    allPlans?: BibleReadingPlan[];\r\n    streak?: number;\r\n}\r\n\r\nexport default function SettingsView({ onReschedule, progress = [], allPlans = [], streak = 0 }: SettingsViewProps) {\r\n    const { theme, setTheme, resolvedTheme } = useTheme();\r\n    const [mounted, setMounted] = useState(false);\r\n    const [confirmReset, setConfirmReset] = useState(false);\r\n    const [fontSize, setFontSize] = useState(() =>\r\n        typeof window !== 'undefined' ? localStorage.getItem('bible_font_size') || 'medium' : 'medium'\r\n    );\r\n    const [autoPlay, setAutoPlay] = useState(() =>\r\n        typeof window !== 'undefined' ? localStorage.getItem('bible_autoplay') === 'true' : false\r\n    );\r\n    const [dailyVerse, setDailyVerse] = useState(() =>\r\n        typeof window !== 'undefined' ? localStorage.getItem('bible_daily_verse') !== 'false' : true\r\n    );\r\n    const [autoBackup, setAutoBackup] = useState(() =>\r\n        typeof window !== 'undefined' ? localStorage.getItem('bible_auto_backup') !== 'false' : true\r\n    );\r\n\r\n    // Notification settings state\r\n    const [notifSettings, setNotifSettings] = useState<NotificationSettings>(DEFAULT_SETTINGS);\r\n    const [shareSettings, setShareSettings] = useState<ShareSettings>(DEFAULT_SHARE_SETTINGS);\r\n    const [newPhone, setNewPhone] = useState(\"\");\r\n\r\n    useEffect(() => {\r\n        setMounted(true);\r\n        setNotifSettings(loadNotificationSettings());\r\n        setShareSettings(loadShareSettings());\r\n    }, []);\r\n\r\n    const updateNotifSetting = useCallback(async <K extends keyof NotificationSettings>(\r\n        key: K,\r\n        value: NotificationSettings[K]\r\n    ) => {\r\n        const updated = { ...notifSettings, [key]: value };\r\n        setNotifSettings(updated);\r\n        saveNotificationSettings(updated);\r\n        if (updated.enabled) {\r\n            await scheduleDailyNotifications(updated);\r\n        } else {\r\n            await cancelAllDailyNotifications();\r\n        }\r\n    }, [notifSettings]);\r\n\r\n    const updateShareSetting = useCallback(async <K extends keyof ShareSettings>(\r\n        key: K,\r\n        value: ShareSettings[K]\r\n    ) => {\r\n        const updated = { ...shareSettings, [key]: value };\r\n        setShareSettings(updated);\r\n        saveShareSettings(updated);\r\n        if (updated.enabled) {\r\n            await scheduleShareReminder(updated);\r\n        } else {\r\n            await cancelShareReminders();\r\n        }\r\n    }, [shareSettings]);\r\n\r\n    // Stats from localStorage\r\n    const stats = useMemo(() => {\r\n        if (typeof window === 'undefined') return { total: 0, streak: 0, startDate: '' };\r\n        try {\r\n            const data = localStorage.getItem('guest_bible_progress');\r\n            const parsed = data ? JSON.parse(data) : [];\r\n            const total = Array.isArray(parsed) ? parsed.length : 0;\r\n            return { total, streak: 0, startDate: '2026.01.01' };\r\n        } catch {\r\n            return { total: 0, streak: 0, startDate: '' };\r\n        }\r\n    }, []);\r\n\r\n    const handleFontSizeChange = (size: string) => {\r\n        setFontSize(size);\r\n        localStorage.setItem('bible_font_size', size);\r\n        // Apply CSS variable globally + notify other components\r\n        const scales: Record<string, string> = { small: '0.88', medium: '1', large: '1.15' };\r\n        document.documentElement.style.setProperty('--font-scale', scales[size] || '1');\r\n        window.dispatchEvent(new CustomEvent('bible-font-change'));\r\n    };\r\n\r\n    const handleAutoPlayChange = (val: boolean) => {\r\n        setAutoPlay(val);\r\n        localStorage.setItem('bible_autoplay', String(val));\r\n    };\r\n\r\n    const handleDailyVerseChange = (val: boolean) => {\r\n        setDailyVerse(val);\r\n        localStorage.setItem('bible_daily_verse', String(val));\r\n    };\r\n\r\n    const handleAutoBackupChange = (val: boolean) => {\r\n        setAutoBackup(val);\r\n        localStorage.setItem('bible_auto_backup', String(val));\r\n    };\r\n\r\n    const handleReset = () => {\r\n        if (confirmReset) {\r\n            localStorage.removeItem('guest_bible_progress');\r\n            window.location.reload();\r\n        } else {\r\n            setConfirmReset(true);\r\n            setTimeout(() => setConfirmReset(false), 3000);\r\n        }\r\n    };\r\n\r\n    const handleExport = () => {\r\n        const data = localStorage.getItem('guest_bible_progress');\r\n        if (!data) return;\r\n        const blob = new Blob([JSON.stringify({ progress: JSON.parse(data), exportDate: new Date().toISOString(), version: \"1.2.0\" }, null, 2)], { type: \"application/json\" });\r\n        const url = URL.createObjectURL(blob);\r\n        const a = document.createElement(\"a\");\r\n        a.href = url;\r\n        a.download = `?깃꼍365-諛깆뾽-${new Date().toISOString().slice(0, 10)}.json`;\r\n        a.click();\r\n        URL.revokeObjectURL(url);\r\n    };\r\n\r\n    const handleImportClick = () => {\r\n        document.getElementById('import-file')?.click();\r\n    };\r\n\r\n    const handleFileChange = (e: React.ChangeEvent<HTMLInputElement>) => {\r\n        const file = e.target.files?.[0];\r\n        if (!file) return;\r\n\r\n        const reader = new FileReader();\r\n        reader.onload = (event) => {\r\n            try {\r\n                const json = JSON.parse(event.target?.result as string);\r\n                if (json.progress && Array.isArray(json.progress)) {\r\n                    if (confirm(`?뱟 ${json.exportDate?.slice(0, 10) || '遺덈챸'}???곗씠?곕줈 蹂듭썝?섏떆寃좎뒿?덇퉴?\\n珥?${json.progress.length}?쇱쓽 ?쎄린 湲곕줉???덉뒿?덈떎.`)) {\r\n                        localStorage.setItem('guest_bible_progress', JSON.stringify(json.progress));\r\n                        alert(\"??蹂듭썝???꾨즺?섏뿀?듬땲??\");\r\n                        window.location.reload();\r\n                    }\r\n                } else {\r\n                    alert(\"???щ컮瑜?諛깆뾽 ?뚯씪???꾨떃?덈떎.\");\r\n                }\r\n            } catch (err) {\r\n                alert(\"???뚯씪 ?쎄린 ?ㅽ뙣: \" + err);\r\n            }\r\n        };\r\n        reader.readAsText(file);\r\n        reader.readAsText(file);\r\n    };\r\n\r\n    const handleAddPhone = () => {\r\n        if (!newPhone) return;\r\n        const currentPhones = shareSettings.recipientPhones || [];\r\n        if (!currentPhones.includes(newPhone)) {\r\n            updateShareSetting('recipientPhones', [...currentPhones, newPhone]);\r\n        }\r\n        setNewPhone(\"\");\r\n    };\r\n\r\n    const handleRemovePhone = (phone: string) => {\r\n        const currentPhones = shareSettings.recipientPhones || [];\r\n        updateShareSetting('recipientPhones', currentPhones.filter(p => p !== phone));\r\n    };\r\n\r\n    if (!mounted) return null;\r\n\r\n\r\n\r\n    if (!mounted) return null;\r\n\r\n    return (\r\n        <div className=\"animate-in fade-in slide-in-from-right-4 duration-500 space-y-8\">\r\n            {/* Header */}\r\n            <div className=\"flex items-center gap-3 px-2\">\r\n                <div className=\"p-2.5 rounded-2xl bg-gradient-to-br from-primary/20 to-primary/5\">\r\n                    <SettingsIcon size={22} className=\"text-primary\" />\r\n                </div>\r\n                <div>\r\n                    <h2 className=\"text-xl font-serif font-bold\">?ㅼ젙</h2>\r\n                    <p className=\"text-xs text-muted-foreground\">?섎쭔???쎄린 ?섍꼍??留뚮뱶?몄슂</p>\r\n                </div>\r\n            </div>\r\n\r\n            {/* === My Journey Stats Banner === */}\r\n            <SmartCard variant=\"elevated\" className=\"bg-gradient-to-br from-primary/5 via-background to-primary/5 border border-primary/10 dark:border-primary/20\">\r\n                <div className=\"flex items-center justify-between\">\r\n                    <div className=\"flex items-center gap-3\">\r\n                        <div className=\"w-12 h-12 rounded-2xl bg-primary/10 flex items-center justify-center\">\r\n                            <Award size={24} className=\"text-primary\" />\r\n                        </div>\r\n                        <div>\r\n                            <p className=\"text-sm font-bold text-foreground\">?섏쓽 ?ъ젙</p>\r\n                            <p className=\"text-xs text-muted-foreground\">{stats.startDate}遺???쒖옉</p>\r\n                        </div>\r\n                    </div>\r\n                    <div className=\"text-right\">\r\n                        <p className=\"text-3xl font-display font-bold text-primary\">{stats.total}</p>\r\n                        <p className=\"text-[10px] text-muted-foreground font-bold uppercase tracking-widest\">???꾨즺</p>\r\n                    </div>\r\n                </div>\r\n            </SmartCard>\r\n\r\n            {/* === Appearance === */}\r\n            <Section title=\"?붾㈃ ?ㅼ젙\" icon={<Sparkles size={14} />}>\r\n                <SettingRow\r\n                    icon={resolvedTheme === 'dark' ? Moon : Sun}\r\n                    iconColor=\"text-amber-500\"\r\n                    iconBg=\"bg-amber-500/10\"\r\n                    label=\"?ㅽ겕 紐⑤뱶\"\r\n                    description=\"?덉쓽 ?쇰줈瑜?以꾩뿬以띾땲??"\r\n                    action={\r\n                        <ToggleSwitch\r\n                            checked={resolvedTheme === 'dark'}\r\n                            onCheckedChange={(c) => setTheme(c ? 'dark' : 'light')}\r\n                            showIcon={true}\r\n                        />\r\n                    }\r\n                />\r\n                <div className=\"px-4 pb-4\">\r\n                    <p className=\"text-xs font-bold text-muted-foreground mb-2.5 flex items-center gap-1.5\">\r\n                        <Type size={12} /> 湲???ш린\r\n                    </p>\r\n                    <OptionSelector\r\n                        options={[\r\n                            { id: 'small', label: '?묎쾶' },\r\n                            { id: 'medium', label: '蹂댄넻' },\r\n                            { id: 'large', label: '?ш쾶' },\r\n                        ]}\r\n                        value={fontSize}\r\n                        onChange={handleFontSizeChange}\r\n                    />\r\n                </div>\r\n            </Section>\r\n\r\n            {/* === Reading Experience === */}\r\n            <Section title=\"?쎄린 ?섍꼍\" icon={<BookOpen size={14} />}>\r\n                <SettingRow\r\n                    icon={Volume2}\r\n                    iconColor=\"text-violet-500\"\r\n                    iconBg=\"bg-violet-500/10\"\r\n                    label=\"?곸긽 ?먮룞 ?ъ깮\"\r\n                    description=\"?ㅻ뒛???쎄린?먯꽌 ?곸긽???먮룞 ?ъ깮?⑸땲??"\r\n                    action={\r\n                        <ToggleSwitch checked={autoPlay} onCheckedChange={handleAutoPlayChange} />\r\n                    }\r\n                />\r\n                <SettingRow\r\n                    icon={Heart}\r\n                    iconColor=\"text-rose-500\"\r\n                    iconBg=\"bg-rose-500/10\"\r\n                    label=\"寃⑸젮 硫붿떆吏\"\r\n                    description=\"留ㅼ씪 ?덈줈??寃⑸젮??留먯????쒖떆?⑸땲??"\r\n                    action={\r\n                        <ToggleSwitch checked={dailyVerse} onCheckedChange={handleDailyVerseChange} />\r\n                    }\r\n                />\r\n            </Section>\r\n\r\n            {/* === Lock Screen Notification === */}\r\n            <Section title=\"?좉툑?붾㈃ ?뚮┝\" icon={<Bell size={14} />}>\r\n                <SettingRow\r\n                    icon={notifSettings.enabled ? Bell : BellOff}\r\n                    iconColor={notifSettings.enabled ? \"text-blue-500\" : \"text-muted-foreground\"}\r\n                    iconBg={notifSettings.enabled ? \"bg-blue-500/10\" : \"bg-muted/30\"}\r\n                    label=\"?좉툑?붾㈃ ?뚮┝\"\r\n                    description=\"留ㅼ씪 吏?뺥븳 ?쒓컙???쎄린 ?뚮┝???쒖떆?⑸땲??"\r\n                    action={\r\n                        <ToggleSwitch\r\n                            checked={notifSettings.enabled}\r\n                            onCheckedChange={(c) => updateNotifSetting('enabled', c)}\r\n                        />\r\n                    }\r\n                />\r\n\r\n                {notifSettings.enabled && (\r\n                    <>\r\n                        {/* Time Picker */}\r\n                        <div className=\"px-4 py-3.5\">\r\n                            <div className=\"flex items-center justify-between mb-3\">\r\n                                <div className=\"flex items-center gap-3.5\">\r\n                                    <div className=\"p-2 rounded-xl bg-indigo-500/10\">\r\n                                        <Clock size={16} className=\"text-indigo-500\" />\r\n                                    </div>\r\n                                    <div>\r\n                                        <p className=\"text-sm font-semibold text-foreground\">?뚮┝ ?쒓컙</p>\r\n                                        <p className=\"text-[10px] text-muted-foreground mt-0.5\">留ㅼ씪 ???쒓컙???뚮┝???쒖떆?⑸땲??/p>\r\n                                    </div>\r\n                                </div>\r\n                                <div className=\"flex items-center gap-1 bg-muted/40 rounded-xl px-1 py-1\">\r\n                                    <select\r\n                                        value={notifSettings.hour}\r\n                                        onChange={(e) => updateNotifSetting('hour', parseInt(e.target.value))}\r\n                                        className=\"bg-transparent text-center text-lg font-bold text-foreground appearance-none cursor-pointer w-10 outline-none\"\r\n                                    >\r\n                                        {Array.from({ length: 24 }, (_, i) => (\r\n                                            <option key={i} value={i}>{String(i).padStart(2, '0')}</option>\r\n                                        ))}\r\n                                    </select>\r\n                                    <span className=\"text-lg font-bold text-muted-foreground\">:</span>\r\n                                    <select\r\n                                        value={notifSettings.minute}\r\n                                        onChange={(e) => updateNotifSetting('minute', parseInt(e.target.value))}\r\n                                        className=\"bg-transparent text-center text-lg font-bold text-foreground appearance-none cursor-pointer w-10 outline-none\"\r\n                                    >\r\n                                        {Array.from({ length: 12 }, (_, i) => i * 5).map(m => (\r\n                                            <option key={m} value={m}>{String(m).padStart(2, '0')}</option>\r\n                                        ))}\r\n                                    </select>\r\n                                </div>\r\n                            </div>\r\n\r\n                            {/* Preset Buttons */}\r\n                            <div className=\"flex gap-1.5 p-1 bg-muted/30 rounded-xl\">\r\n                                {[\r\n                                    { label: '?똿 ?덈꼍', h: 5, m: 30 },\r\n                                    { label: '?截??꾩묠', h: 7, m: 0 },\r\n                                    { label: '?뙔 ???, h: 21, m: 0 },\r\n                                ].map(preset => {\r\n                                    const isActive = notifSettings.hour === preset.h && notifSettings.minute === preset.m;\r\n                                    return (\r\n                                        <button\r\n                                            key={preset.label}\r\n                                            onClick={() => {\r\n                                                const updated = { ...notifSettings, hour: preset.h, minute: preset.m };\r\n                                                setNotifSettings(updated);\r\n                                                saveNotificationSettings(updated);\r\n                                                if (updated.enabled) scheduleDailyNotifications(updated);\r\n                                            }}\r\n                                            className={cn(\r\n                                                \"flex-1 px-3 py-2 rounded-lg text-xs font-bold transition-all duration-300\",\r\n                                                isActive\r\n                                                    ? \"bg-primary text-primary-foreground shadow-sm\"\r\n                                                    : \"text-muted-foreground hover:text-foreground hover:bg-muted/50\"\r\n                                            )}\r\n                                        >\r\n                                            {preset.label}\r\n                                        </button>\r\n                                    );\r\n                                })}\r\n                            </div>\r\n                        </div>\r\n\r\n                        {/* Day Selector */}\r\n                        <div className=\"px-4 py-3.5 border-t border-border/30 dark:border-white/5\">\r\n                            <p className=\"text-xs font-bold text-muted-foreground mb-2.5\">諛섎났 ?붿씪</p>\r\n                            <div className=\"flex gap-1\">\r\n                                {['??, '??, '??, '紐?, '湲?, '??, '??].map((day, idx) => (\r\n                                    <button\r\n                                        key={day}\r\n                                        onClick={() => {\r\n                                            const newDays = [...notifSettings.days];\r\n                                            newDays[idx] = !newDays[idx];\r\n                                            // Prevent deselecting all\r\n                                            if (newDays.some(d => d)) {\r\n                                                updateNotifSetting('days', newDays);\r\n                                            }\r\n                                        }}\r\n                                        className={cn(\r\n                                            \"flex-1 py-2 rounded-lg text-xs font-bold transition-all duration-300\",\r\n                                            notifSettings.days[idx]\r\n                                                ? \"bg-primary text-primary-foreground shadow-sm\"\r\n                                                : \"bg-muted/30 text-muted-foreground hover:bg-muted/50\"\r\n                                        )}\r\n                                    >\r\n                                        {day}\r\n                                    </button>\r\n                                ))}\r\n                            </div>\r\n                        </div>\r\n\r\n                        {/* Content Preview Toggle */}\r\n                        <SettingRow\r\n                            icon={BookOpen}\r\n                            iconColor=\"text-emerald-500\"\r\n                            iconBg=\"bg-emerald-500/10\"\r\n                            label=\"援ъ젅 誘몃━蹂닿린\"\r\n                            description=\"?뚮┝???ㅻ뒛???쎄린 援ъ젅???쒖떆?⑸땲??"\r\n                            action={\r\n                                <ToggleSwitch\r\n                                    checked={notifSettings.showPreview}\r\n                                    onCheckedChange={(c) => updateNotifSetting('showPreview', c)}\r\n                                />\r\n                            }\r\n                        />\r\n\r\n                        {/* Sound Toggle */}\r\n                        <SettingRow\r\n                            icon={notifSettings.silent ? VolumeX : Volume2}\r\n                            iconColor={notifSettings.silent ? \"text-muted-foreground\" : \"text-purple-500\"}\r\n                            iconBg={notifSettings.silent ? \"bg-muted/30\" : \"bg-purple-500/10\"}\r\n                            label=\"臾댁쓬 ?뚮┝\"\r\n                            description=\"?뚮━ ?놁씠 議곗슜???뚮┝???쒖떆?⑸땲??"\r\n                            action={\r\n                                <ToggleSwitch\r\n                                    checked={notifSettings.silent}\r\n                                    onCheckedChange={(c) => updateNotifSetting('silent', c)}\r\n                                />\r\n                            }\r\n                        />\r\n                    </>\r\n                )}\r\n            </Section>\r\n\r\n            {/* === Share & Community === */}\r\n            <Section title=\"怨듭쑀 諛??곌껐\" icon={<Share2 size={14} />}>\r\n                <SettingRow\r\n                    icon={Share2}\r\n                    iconColor=\"text-blue-500\"\r\n                    iconBg=\"bg-blue-500/10\"\r\n                    label=\"吏湲?怨듭쑀?섍린\"\r\n                    description=\"移쒓뎄?ㅼ뿉寃??깃꼍 ?쎄린瑜?異붿쿇?⑸땲??"\r\n                    onClick={() => shareContent(\"?깃꼍 365\", \"?④퍡 ?깃꼍 ?쎄린???꾩쟾?댁슂! 留ㅼ씪 議곌툑???쎈떎蹂대㈃ 1?꾩뿉 1?낆쓣 ?????덉뒿?덈떎.\", \"https://bible-365-app.vercel.app\")}\r\n                />\r\n\r\n                {/* Automation Share */}\r\n                <SettingRow\r\n                    icon={shareSettings.enabled ? Repeat : CalendarIcon}\r\n                    iconColor={shareSettings.enabled ? \"text-pink-500\" : \"text-muted-foreground\"}\r\n                    iconBg={shareSettings.enabled ? \"bg-pink-500/10\" : \"bg-muted/30\"}\r\n                    label=\"?먮룞 怨듭쑀 ?덉빟\"\r\n                    description=\"?뺢린?곸쑝濡?怨듭쑀 ?뚮┝??諛쏆뒿?덈떎\"\r\n                    action={\r\n                        <ToggleSwitch\r\n                            checked={shareSettings.enabled}\r\n                            onCheckedChange={(c) => updateShareSetting('enabled', c)}\r\n                        />\r\n                    }\r\n                />\r\n\r\n                {shareSettings.enabled && (\r\n                    <div className=\"px-4 pb-4 space-y-4 animate-in slide-in-from-top-2 duration-300\">\r\n                        {/* Frequency Selector */}\r\n                        <div>\r\n                            <p className=\"text-xs font-bold text-muted-foreground mb-2\">?덉빟 二쇨린</p>\r\n                            <div className=\"flex gap-1 p-1 bg-muted/30 rounded-xl\">\r\n                                {[\r\n                                    { id: 'daily', label: '留ㅼ씪' },\r\n                                    { id: 'weekly', label: '留ㅼ＜' },\r\n                                    { id: 'monthly', label: '留ㅼ썡' },\r\n                                    { id: 'yearly', label: '留ㅻ뀈' }\r\n                                ].map(freq => (\r\n                                    <button\r\n                                        key={freq.id}\r\n                                        onClick={() => updateShareSetting('frequency', freq.id as ShareFrequency)}\r\n                                        className={cn(\r\n                                            \"flex-1 py-1.5 rounded-lg text-xs font-bold transition-all\",\r\n                                            shareSettings.frequency === freq.id\r\n                                                ? \"bg-primary text-primary-foreground shadow-sm\"\r\n                                                : \"text-muted-foreground hover:bg-muted/50\"\r\n                                        )}\r\n                                    >\r\n                                        {freq.label}\r\n                                    </button>\r\n                                ))}\r\n                            </div>\r\n                        </div>\r\n\r\n                        {/* Dynamic Inputs based on Frequency */}\r\n                        <div className=\"flex gap-3\">\r\n                            {/* Weekday Selector (Weekly) */}\r\n                            {shareSettings.frequency === 'weekly' && (\r\n                                <div className=\"flex-1\">\r\n                                    <p className=\"text-xs font-bold text-muted-foreground mb-2\">?붿씪 ?좏깮</p>\r\n                                    <select\r\n                                        value={shareSettings.weekday || 2}\r\n                                        onChange={(e) => updateShareSetting('weekday', parseInt(e.target.value))}\r\n                                        className=\"w-full bg-muted/30 rounded-lg px-3 py-2 text-sm font-bold outline-none\"\r\n                                    >\r\n                                        <option value={2}>?붿슂??/option>\r\n                                        <option value={3}>?붿슂??/option>\r\n                                        <option value={4}>?섏슂??/option>\r\n                                        <option value={5}>紐⑹슂??/option>\r\n                                        <option value={6}>湲덉슂??/option>\r\n                                        <option value={7}>?좎슂??/option>\r\n                                        <option value={1}>?쇱슂??/option>\r\n                                    </select>\r\n                                </div>\r\n                            )}\r\n\r\n                            {/* Day of Month (Monthly/Yearly) */}\r\n                            {(shareSettings.frequency === 'monthly' || shareSettings.frequency === 'yearly') && (\r\n                                <div className=\"flex-1\">\r\n                                    <p className=\"text-xs font-bold text-muted-foreground mb-2\">?좎쭨 ?좏깮</p>\r\n                                    <select\r\n                                        value={shareSettings.dayOfMonth || 1}\r\n                                        onChange={(e) => updateShareSetting('dayOfMonth', parseInt(e.target.value))}\r\n                                        className=\"w-full bg-muted/30 rounded-lg px-3 py-2 text-sm font-bold outline-none\"\r\n                                    >\r\n                                        {Array.from({ length: 31 }, (_, i) => i + 1).map(d => (\r\n                                            <option key={d} value={d}>{d}??/option>\r\n                                        ))}\r\n                                    </select>\r\n                                </div>\r\n                            )}\r\n\r\n                            {/* Month (Yearly) */}\r\n                            {shareSettings.frequency === 'yearly' && (\r\n                                <div className=\"flex-1\">\r\n                                    <p className=\"text-xs font-bold text-muted-foreground mb-2\">???좏깮</p>\r\n                                    <select\r\n                                        value={shareSettings.month || 1}\r\n                                        onChange={(e) => updateShareSetting('month', parseInt(e.target.value))}\r\n                                        className=\"w-full bg-muted/30 rounded-lg px-3 py-2 text-sm font-bold outline-none\"\r\n                                    >\r\n                                        {Array.from({ length: 12 }, (_, i) => i + 1).map(m => (\r\n                                            <option key={m} value={m}>{m}??/option>\r\n                                        ))}\r\n                                    </select>\r\n                                </div>\r\n                            )}\r\n\r\n                            {/* Time Picker (Always visible) */}\r\n                            <div className=\"flex-1\">\r\n                                <p className=\"text-xs font-bold text-muted-foreground mb-2\">?쒓컙</p>\r\n                                <div className=\"flex items-center gap-1 bg-muted/30 rounded-lg px-3 py-1.5 justify-center\">\r\n                                    <select\r\n                                        value={shareSettings.hour}\r\n                                        onChange={(e) => updateShareSetting('hour', parseInt(e.target.value))}\r\n                                        className=\"bg-transparent text-center font-bold outline-none w-12 appearance-none\" style={{ textAlignLast: 'center' }}\r\n                                    >\r\n                                        {Array.from({ length: 24 }, (_, i) => (\r\n                                            <option key={i} value={i}>{String(i).padStart(2, '0')}</option>\r\n                                        ))}\r\n                                    </select>\r\n                                    <span className=\"font-bold text-lg\">:</span>\r\n                                    <select\r\n                                        value={shareSettings.minute}\r\n                                        onChange={(e) => updateShareSetting('minute', parseInt(e.target.value))}\r\n                                        className=\"bg-transparent text-center font-bold outline-none w-12 appearance-none\" style={{ textAlignLast: 'center' }}\r\n                                    >\r\n                                        {Array.from({ length: 12 }, (_, i) => i * 5).map(m => (\r\n                                            <option key={m} value={m}>{String(m).padStart(2, '0')}</option>\r\n                                        ))}\r\n                                    </select>\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n\r\n                        {/* Template Selector */}\r\n                        <div>\r\n                            <p className=\"text-xs font-bold text-muted-foreground mb-2\">怨듭쑀 ?쒗뵆由?/p>\r\n                            <div className=\"flex gap-2\">\r\n                                <button\r\n                                    onClick={() => updateShareSetting('template', 'reading')}\r\n                                    className={cn(\r\n                                        \"flex-1 p-3 rounded-xl border transition-all text-left\",\r\n                                        shareSettings.template === 'reading'\r\n                                            ? \"border-primary bg-primary/5\"\r\n                                            : \"border-border/50 hover:bg-muted/30\"\r\n                                    )}\r\n                                >\r\n                                    <div className=\"flex items-center gap-2 mb-1\">\r\n                                        <BookOpen size={14} className=\"text-primary\" />\r\n                                        <span className=\"text-xs font-bold\">?ㅻ뒛??留먯?</span>\r\n                                    </div>\r\n                                    <p className=\"text-[10px] text-muted-foreground line-clamp-1\">\r\n                                        \"?쒖큹???섎굹?섏씠...\" ???ㅻ뒛 ?쎌쓣 援ъ젅 怨듭쑀\r\n                                    </p>\r\n                                </button>\r\n                                <button\r\n                                    onClick={() => updateShareSetting('template', 'stats')}\r\n                                    className={cn(\r\n                                        \"flex-1 p-3 rounded-xl border transition-all text-left\",\r\n                                        shareSettings.template === 'stats'\r\n                                            ? \"border-primary bg-primary/5\"\r\n                                            : \"border-border/50 hover:bg-muted/30\"\r\n                                    )}\r\n                                >\r\n                                    <div className=\"flex items-center gap-2 mb-1\">\r\n                                        <Award size={14} className=\"text-orange-500\" />\r\n                                        <span className=\"text-xs font-bold\">?쎄린 ?꾪솴</span>\r\n                                    </div>\r\n                                    <p className=\"text-[10px] text-muted-foreground line-clamp-1\">\r\n                                        ?곗냽 ?쎄린??諛?吏꾪뻾 ?곹솴 怨듭쑀\r\n                                    </p>\r\n                                </button>\r\n                            </div>\r\n                        </div>\r\n\r\n                        {/* Share Channel Selector */}\r\n                        <div>\r\n                            <p className=\"text-xs font-bold text-muted-foreground mb-2\">怨듭쑀 諛⑸쾿</p>\r\n                            <div className=\"flex gap-1.5 p-1 bg-muted/30 rounded-xl\">\r\n                                {[\r\n                                    { id: 'native' as ShareChannel, label: '湲곕낯', icon: <Share2 size={12} /> },\r\n                                    { id: 'sms' as ShareChannel, label: '臾몄옄', icon: <MessageSquare size={12} /> },\r\n                                    { id: 'kakao' as ShareChannel, label: '移댁뭅?ㅽ넚', icon: <Phone size={12} /> },\r\n                                ].map(ch => (\r\n                                    <button\r\n                                        key={ch.id}\r\n                                        onClick={() => updateShareSetting('channel', ch.id)}\r\n                                        className={cn(\r\n                                            \"flex-1 flex items-center justify-center gap-1.5 px-3 py-2 rounded-lg text-xs font-bold transition-all duration-300\",\r\n                                            shareSettings.channel === ch.id\r\n                                                ? \"bg-primary text-primary-foreground shadow-sm\"\r\n                                                : \"text-muted-foreground hover:text-foreground hover:bg-muted/50\"\r\n                                        )}\r\n                                    >\r\n                                        {ch.icon}\r\n                                        {ch.label}\r\n                                    </button>\r\n                                ))}\r\n                            </div>\r\n                        </div>\r\n\r\n                        {/* SMS Phone Number Input */}\r\n                        {shareSettings.channel === 'sms' && (\r\n                            <div className=\"animate-in slide-in-from-top-2 duration-300\">\r\n                                <p className=\"text-xs font-bold text-muted-foreground mb-2\">?섏떊 踰덊샇 愿由?({shareSettings.recipientPhones?.length || 0}紐?</p>\r\n\r\n                                {/* Add New Phone */}\r\n                                <div className=\"flex gap-2 mb-3\">\r\n                                    <input\r\n                                        type=\"tel\"\r\n                                        value={newPhone}\r\n                                        onChange={(e) => setNewPhone(e.target.value.replace(/[^0-9-]/g, ''))} // Allow only numbers and dashes\r\n                                        placeholder=\"010-1234-5678\"\r\n                                        className=\"flex-1 bg-muted/30 rounded-lg px-4 py-2.5 text-sm font-bold outline-none border border-border/30 focus:border-primary/50 focus:ring-1 focus:ring-primary/20 transition-all placeholder:text-muted-foreground/50\"\r\n                                        onKeyDown={(e) => e.key === 'Enter' && handleAddPhone()}\r\n                                    />\r\n                                    <button\r\n                                        onClick={handleAddPhone}\r\n                                        disabled={!newPhone || newPhone.length < 10}\r\n                                        className=\"px-4 py-2 bg-primary/10 text-primary rounded-lg text-sm font-bold hover:bg-primary/20 transition-colors disabled:opacity-50 disabled:cursor-not-allowed\"\r\n                                    >\r\n                                        異붽?\r\n                                    </button>\r\n                                </div>\r\n\r\n                                {/* Phone List */}\r\n                                <div className=\"space-y-2 max-h-40 overflow-y-auto no-scrollbar\">\r\n                                    {shareSettings.recipientPhones?.map((phone, idx) => (\r\n                                        <div key={idx} className=\"flex items-center justify-between p-3 rounded-xl bg-muted/20 border border-border/30\">\r\n                                            <div className=\"flex items-center gap-3\">\r\n                                                <div className=\"w-8 h-8 rounded-full bg-muted/50 flex items-center justify-center\">\r\n                                                    <MessageSquare size={14} className=\"text-muted-foreground\" />\r\n                                                </div>\r\n                                                <span className=\"text-sm font-bold\">{phone}</span>\r\n                                            </div>\r\n                                            <button\r\n                                                onClick={() => handleRemovePhone(phone)}\r\n                                                className=\"p-1.5 hover:bg-destructive/10 text-muted-foreground hover:text-destructive rounded-lg transition-colors\"\r\n                                            >\r\n                                                <Trash2 size={14} />\r\n                                            </button>\r\n                                        </div>\r\n                                    ))}\r\n                                    {(!shareSettings.recipientPhones || shareSettings.recipientPhones.length === 0) && (\r\n                                        <div className=\"text-center py-4 text-xs text-muted-foreground bg-muted/10 rounded-xl border border-dashed border-border/40\">\r\n                                            ?깅줉??踰덊샇媛 ?놁뒿?덈떎\r\n                                        </div>\r\n                                    )}\r\n                                </div>\r\n                                <div className=\"mt-2 px-1 text-[10px] text-muted-foreground space-y-1\">\r\n                                    <p>* ?щ윭 紐낆뿉寃??숈떆??臾몄옄瑜?諛쒖넚?⑸땲??(?듭떊???붽툑 遺怨쇰맆 ???덉쓬)</p>\r\n                                    <p>* ?꾩씠?곗? 洹몃９ 硫붿떆吏(MMS), ?덈뱶濡쒖씠?쒕뒗 媛쒕퀎 諛쒖넚?쇰줈 泥섎━?????덉뒿?덈떎.</p>\r\n                                </div>\r\n                            </div>\r\n                        )}\r\n\r\n                        {/* KakaoTalk Info */}\r\n                        {shareSettings.channel === 'kakao' && (\r\n                            <div className=\"animate-in slide-in-from-top-2 duration-300 space-y-3\">\r\n                                <div className=\"flex items-center gap-3 p-3 rounded-xl bg-[#FEE500]/10 border border-[#FEE500]/30\">\r\n                                    <div className=\"w-8 h-8 rounded-full bg-[#FEE500] flex items-center justify-center flex-shrink-0\">\r\n                                        <span className=\"text-[#3C1E1E] text-sm font-black\">K</span>\r\n                                    </div>\r\n                                    <div className=\"flex-1\">\r\n                                        <p className=\"text-xs font-bold\">移댁뭅?ㅽ넚 怨듭쑀</p>\r\n                                        <p className=\"text-[10px] text-muted-foreground mt-0.5\">怨듭쑀 ??移댁뭅?ㅽ넚 ?깆씠 ?ㅽ뻾?⑸땲??/p>\r\n                                    </div>\r\n                                </div>\r\n\r\n                                <div>\r\n                                    <p className=\"text-xs font-bold text-muted-foreground mb-2\">JavaScript ???ㅼ젙</p>\r\n                                    <div className=\"relative\">\r\n                                        <input\r\n                                            type=\"text\"\r\n                                            value={process.env.NEXT_PUBLIC_KAKAO_JS_KEY ? \"******** (?섍꼍蹂???ㅼ젙??\" : (shareSettings.kakaoJsKey || '')}\r\n                                            onChange={(e) => !process.env.NEXT_PUBLIC_KAKAO_JS_KEY && updateShareSetting('kakaoJsKey', e.target.value)}\r\n                                            disabled={!!process.env.NEXT_PUBLIC_KAKAO_JS_KEY}\r\n                                            placeholder=\"Kakao Developers JS Key ?낅젰\"\r\n                                            className=\"w-full bg-muted/30 rounded-lg px-4 py-2.5 text-sm font-mono outline-none border border-border/30 focus:border-[#FEE500] focus:ring-1 focus:ring-[#FEE500]/20 transition-all placeholder:text-muted-foreground/50 disabled:opacity-70 disabled:cursor-not-allowed\"\r\n                                        />\r\n                                        {!!process.env.NEXT_PUBLIC_KAKAO_JS_KEY && (\r\n                                            <div className=\"absolut