SO 8601 湲곌컙 (PT15M30S)??遺??⑥쐞濡?蹂??(諛섏삱由?\r\n */\r\nexport function parseDurationToMinutes(duration: string): number {\r\n    const match = duration.match(/PT(?:(\\d+)H)?(?:(\\d+)M)?(?:(\\d+)S)?/);\r\n    if (!match) return 0;\r\n\r\n    const hours = parseInt(match[1] || '0');\r\n    const minutes = parseInt(match[2] || '0');\r\n    const seconds = parseInt(match[3] || '0');\r\n\r\n    const totalMinutes = (hours * 60) + minutes + (seconds >= 30 ? 1 : 0);\r\n    return totalMinutes || 1; // 理쒖냼 1遺?r\n}\r\n\r\n/**\r\n * YouTube API瑜??듯빐 ?ъ깮紐⑸줉??紐⑤뱺 ?곸긽??媛?몄샂 (理쒕? 365媛??댁긽)\r\n * ?곸긽 湲몄씠(duration) ?뺣낫瑜??ы븿?섍린 ?꾪빐 異붽? API ?몄텧 ?섑뻾\r\n */\r\nexport async function fetchYoutubePlaylist(): Promise<YoutubeVideo[]> {\r\n    if (!API_KEY) {\r\n        console.warn('YouTube API Key is missing. Please set NEXT_PUBLIC_YOUTUBE_API_KEY in .env.local');\r\n        return [];\r\n    }\r\n\r\n    // 1. 罹먯떆 ?뺤씤\r\n    const cachedData = localStorage.getItem(CACHE_KEY);\r\n    if (cachedData) {\r\n        const { videos, timestamp } = JSON.parse(cachedData);\r\n        if (Date.now() - timestamp < CACHE_EXPIRY) {\r\n            return videos;\r\n        }\r\n    }\r\n\r\n    // 2. API ?몄텧\r\n    const allVideos: YoutubeVideo[] = [];\r\n    let nextPageToken = '';\r\n\r\n    try {\r\n        do {\r\n            const playlistUrl = `https://www.googleapis.com/youtube/v3/playlistItems?part=snippet&maxResults=50&playlistId=${PLAYLIST_ID}&key=${API_KEY}${nextPageToken ? `&pageToken=${nextPageToken}` : ''}`;\r\n            const response = await fetch(playlistUrl);\r\n            const data = await response.json();\r\n\r\n            if (data.error) {\r\n                throw new Error(data.error.message);\r\n            }\r\n\r\n            const videoIds = data.items.map((item: any) => item.snippet.resourceId.videoId).join(',');\r\n\r\n            // ?곸긽 ?곸꽭 ?뺣낫(湲몄씠 ?ы븿) 媛?몄삤湲?r\n            const videoDetailsUrl = `https://www.googleapis.com/youtube/v3/videos?part=contentDetails&id=${videoIds}&key=${API_KEY}`;\r\n            const detailsResponse = await fetch(videoDetailsUrl);\r\n            const detailsData = await detailsResponse.json();\r\n            const durationMap = new Map(detailsData.items.map((v: any) => [v.id, v.contentDetails.duration]));\r\n\r\n            const items = data.items.map((item: any, index: number) => {\r\n                const title = item.snippet.title;\r\n                const match = title.match(/(\\d+)?뚯감/);\r\n                const dayNumber = match ? parseInt(match[1]) : (allVideos.length + index + 1);\r\n                const videoId = item.snippet.resourceId.videoId;\r\n\r\n                return {\r\n                    videoId: videoId,\r\n                    title: title,\r\n                    dayNumber: dayNumber,\r\n                    thumbnailUrl: item.snippet.thumbnails.high?.url || item.snippet.thumbnails.default?.url,\r\n                    publishedAt: item.snippet.publishedAt,\r\n                    duration: durationMap.get(videoId) as string,\r\n                };\r\n            });\r\n\r\n            allVideos.push(...items);\r\n            nextPageToken = data.nextPageToken;\r\n        } while (nextPageToken);\r\n\r\n        // 3. 罹먯떆 ???r\n        localStorage.setItem(CACHE_KEY, JSON.stringify({\r\n            videos: allVideos,\r\n            timestamp: Date.now()\r\n        }));\r\n\r\n        return allVideos;\r\n    } catch (error) {\r\n        console.error('Failed to fetch YouTube playlist:', error);\r\n        return [];\r\n    }\r\n}\r\n\r\n/**\r\n * ?뱀젙 ?쇱감???대떦?섎뒗 ?곸긽??諛섑솚 (?ъ깮紐⑸줉 ?덉쇅 泥섎━ ?ы븿)\r\n * - 1~245?? ?쒖감??留ㅼ묶\r\n * - 246?? ?곸긽 ?놁쓬\r\n * - 247~354?? 1??諛由??쒕쾲 (246踰덉㎏ ?곸긽遺??\r\n * - 355?? ?ъ깮紐⑸줉 媛??留덉?留?364踰덉㎏) ?곸긽\r\n * - 356~365?? 2??諛由??쒕쾲\r\n */\r\nexport function getVideoForDay(videos: YoutubeVideo[], dayNumber: number): YoutubeVideo | null {\r\n    if (videos.length === 0) return null;\r\n\r\n    const day = dayNumber > 365 ? 365 : dayNumber;\r\n\r\n    if (day <= 245) {\r\n        // 1-245?? ?뺤긽 ?쒕쾲 (index 0~244)\r\n        return videos[day - 1] || null;\r\n    } else if (day === 246) {\r\n        // 246?? ?곸긽 ?놁쓬\r\n        return null;\r\n    } else if (day >= 247 && day <= 354) {\r\n        // 247~354?? 1??諛由?(index = day - 2)\r\n        // ?? 247?쇱감 -> 246踰덉㎏ ?곸긽 (index 245)\r\n        return videos[day - 2] || null;\r\n    } else if (day === 355) {\r\n        // 355?? ?ъ깮紐⑸줉 媛??留덉?留?(364踰덉㎏, index 363)\r\n        return videos[363] || videos[videos.length - 1] || null;\r\n    } else {\r\n        // 356~365?? 2??諛由?(index = day - 3)\r\n        // ?? 356?쇱감 -> 354踰덉㎏ ?곸긽 (index 353)\r\n        return videos[day - 3] || null;\r\n    }\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\user\\Desktop\\AG\\RB\\bible-app\\src\\proxy.ts","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'supabase' is assigned a value but never used.","line":15,"column":11,"nodeType":null,"messageId":"unusedVar","endLine":15,"endColumn":19},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'options' is defined but never used.","line":24,"column":58,"nodeType":null,"messageId":"unusedVar","endLine":24,"endColumn":65}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { createServerClient } from '@supabase/ssr'\r\nimport { NextResponse, type NextRequest } from 'next/server'\r\n\r\nexport async function proxy(request: NextRequest) {\r\n    let response = NextResponse.next({\r\n        request: {\r\n            headers: request.headers,\r\n        },\r\n    })\r\n\r\n    if (!process.env.NEXT_PUBLIC_SUPABASE_URL || !process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY) {\r\n        return response\r\n    }\r\n\r\n    const supabase = createServerClient(\r\n        process.env.NEXT_PUBLIC_SUPABASE_URL,\r\n        process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY,\r\n        {\r\n            cookies: {\r\n                getAll() {\r\n                    return request.cookies.getAll()\r\n                },\r\n                setAll(cookiesToSet) {\r\n                    cookiesToSet.forEach(({ name, value, options }) => request.cookies.set(name, value))\r\n                    response = NextResponse.next({\r\n                        request: {\r\n                            headers: request.headers,\r\n                        },\r\n                    })\r\n                    cookiesToSet.forEach(({ name, value, options }) =>\r\n                        response.cookies.set(name, value, options)\r\n                    )\r\n                },\r\n            },\r\n        }\r\n    )\r\n\r\n    // 由щ떎?대젆??濡쒖쭅 ?쒓굅 (濡쒓렇???섏씠吏 ?ъ슜 ????\r\n    return response\r\n}\r\n\r\nexport const config = {\r\n    matcher: [\r\n        /*\r\n         * ?꾨옒 寃쎈줈瑜??쒖쇅??紐⑤뱺 ?붿껌?????誘몃뱾?⑥뼱 ?ㅽ뻾:\r\n         * - _next/static (?뺤쟻 ?뚯씪)\r\n         * - _next/image (?대?吏 理쒖쟻???뚯씪)\r\n         * - favicon.ico (?뚮퉬肄??뚯씪)\r\n         * - public ?대뜑 ???뚯씪\r\n         */\r\n        '/((?!_next/static|_next/image|favicon.ico|auth|.*\\\\.(?:svg|png|jpg|jpeg|gif|webp)$).*)',\r\n    ],\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\user\\Desktop\\AG\\RB\\bible-app\\src\\store\\useBibleStore.ts","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'UserReading' is defined but never used.","line":6,"column":6,"nodeType":null,"messageId":"unusedVar","endLine":6,"endColumn":17},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":13,"column":19,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":13,"endColumn":22,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[459,462],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[459,462],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":67,"column":142,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":67,"endColumn":145,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[2450,2453],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[2450,2453],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":2,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { create } from 'zustand';\r\nimport { persist, createJSONStorage } from 'zustand/middleware';\r\nimport { createClient } from '@/lib/supabase-client';\r\nimport { Database } from '@/types/supabase';\r\n\r\ntype UserReading = Database['public']['Tables']['user_readings']['Row'];\r\n// Simplified Journal Entry for frontend\r\nexport interface JournalEntry {\r\n    id: string;\r\n    plan_id: number | null;\r\n    content: string;\r\n    mood?: string;\r\n    ai_feedback?: any;\r\n    created_at: string;\r\n}\r\n\r\ninterface BibleState {\r\n    // State\r\n    completedPlanIds: number[];\r\n    streak: number;\r\n    journals: JournalEntry[];\r\n    isLoading: boolean;\r\n    isSyncing: boolean;\r\n\r\n    // Actions\r\n    toggleReading: (planId: number, userId?: string) => Promise<void>;\r\n    addJournal: (entry: Omit<JournalEntry, 'id' | 'created_at'>, userId?: string) => Promise<void>;\r\n    loadInitialData: (userId?: string) => Promise<void>;\r\n    syncWithSupabase: (userId: string) => Promise<void>;\r\n\r\n    // Optimistic Helpers\r\n    isCompleted: (planId: number) => boolean;\r\n}\r\n\r\nexport const useBibleStore = create<BibleState>()(\r\n    persist(\r\n        (set, get) => ({\r\n            completedPlanIds: [],\r\n            streak: 0,\r\n            journals: [],\r\n            isLoading: false,\r\n            isSyncing: false,\r\n\r\n            isCompleted: (planId) => get().completedPlanIds.includes(planId),\r\n\r\n            loadInitialData: async (userId) => {\r\n                // If user is logged in, fetch from Supabase\r\n                if (userId) {\r\n                    set({ isLoading: true });\r\n                    const supabase = createClient();\r\n\r\n                    // Fetch Readings\r\n                    const { data: readings } = await supabase\r\n                        .from('user_readings')\r\n                        .select('plan_id')\r\n                        .eq('user_id', userId);\r\n\r\n                    // Fetch Journals\r\n                    const { data: journals } = await supabase\r\n                        .from('journal_entries')\r\n                        .select('*')\r\n                        .eq('user_id', userId)\r\n                        .order('created_at', { ascending: false });\r\n\r\n                    set({\r\n                        completedPlanIds: readings?.map((r: { plan_id: number }) => r.plan_id) || [],\r\n                        journals: journals?.map((j: { id: string; plan_id: number | null; content: string; mood: string | null; ai_feedback: any; created_at: string; }) => ({\r\n                            id: j.id,\r\n                            plan_id: j.plan_id,\r\n                            content: j.content,\r\n                            mood: j.mood || undefined,\r\n                            ai_feedback: j.ai_feedback,\r\n                            created_at: j.created_at || new Date().toISOString()\r\n                        })) || [],\r\n                        isLoading: false\r\n                    });\r\n                }\r\n                // If guest, rely on persist middleware (localStorage)\r\n            },\r\n\r\n            toggleReading: async (planId, userId) => {\r\n                const { completedPlanIds } = get();\r\n                const isAlreadyCompleted = completedPlanIds.includes(planId);\r\n                const supabase = createClient();\r\n\r\n                // 1. Optimistic Update\r\n                if (isAlreadyCompleted) {\r\n                    set({ completedPlanIds: completedPlanIds.filter(id => id !== planId) });\r\n                } else {\r\n                    set({ completedPlanIds: [...completedPlanIds, planId] });\r\n                }\r\n\r\n                // 2. Supabase Sync (if logged in)\r\n                if (userId) {\r\n                    if (isAlreadyCompleted) {\r\n                        await supabase.from('user_readings')\r\n                            .delete()\r\n                            .eq('user_id', userId)\r\n                            .eq('plan_id', planId);\r\n                    } else {\r\n                        await supabase.from('user_readings')\r\n                            .insert({ user_id: userId, plan_id: planId });\r\n                    }\r\n                }\r\n            },\r\n\r\n            addJournal: async (entry, userId) => {\r\n                const newJournal: JournalEntry = {\r\n                    ...entry,\r\n                    id: crypto.randomUUID(),\r\n                    created_at: new Date().toISOString()\r\n                };\r\n\r\n                // 1. Optimistic Update\r\n                set(state => ({ journals: [newJournal, ...state.journals] }));\r\n\r\n                // 2. Supabase Sync\r\n                if (userId) {\r\n                    const supabase = createClient();\r\n                    await supabase.from('journal_entries').insert({\r\n                        id: newJournal.id,\r\n                        user_id: userId,\r\n                        plan_id: newJournal.plan_id,\r\n                        content: newJournal.content,\r\n                        mood: newJournal.mood,\r\n                        ai_feedback: newJournal.ai_feedback\r\n                    });\r\n                }\r\n            },\r\n\r\n            syncWithSupabase: async (userId) => {\r\n                if (!userId) return;\r\n\r\n                set({ isSyncing: true });\r\n                const supabase = createClient();\r\n                const { completedPlanIds, journals } = get();\r\n\r\n                try {\r\n                    // 1. Sync Readings (Local -> Cloud)\r\n                    // Find readings that are not yet in Supabase (simplified check: IDs in local but not fetched?)\r\n                    // For robustness, we'll try to insert ignore duplicates.\r\n\r\n                    if (completedPlanIds.length > 0) {\r\n                        const readingPayload = completedPlanIds.map((id: number) => ({\r\n                            user_id: userId,\r\n                            plan_id: id,\r\n                            platform: 'web_sync'\r\n                        }));\r\n\r\n                        const { error: readingError } = await supabase\r\n                            .from('user_readings')\r\n                            .upsert(readingPayload, { onConflict: 'user_id, plan_id', ignoreDuplicates: true });\r\n\r\n                        if (readingError) console.error(\"Reading Sync Error:\", readingError);\r\n                    }\r\n\r\n                    // 2. Sync Journals (Local -> Cloud)\r\n                    // Filter journals that might have been created locally (e.g. guest mode)\r\n                    // We assume journals with valid UUIDs might already be there, but let's be safe.\r\n                    // For a true offline-first sync, we'd need a 'synced_at' flag. \r\n                    // Here we simply try to upsert all local journals.\r\n\r\n                    if (journals.length > 0) {\r\n                        const journalPayload = journals.map((j: JournalEntry) => ({\r\n                            id: j.id,\r\n                            user_id: userId,\r\n                            plan_id: j.plan_id,\r\n                            content: j.content,\r\n                            mood: j.mood,\r\n                            ai_feedback: j.ai_feedback,\r\n                            created_at: j.created_at\r\n                        }));\r\n\r\n                        const { error: journalError } = await supabase\r\n                            .from('journal_entries')\r\n                            .upsert(journalPayload, { onConflict: 'id', ignoreDuplicates: true });\r\n\r\n                        if (journalError) console.error(\"Journal Sync Error:\", journalError);\r\n                    }\r\n\r\n                    // 3. Fetch Latest Data from Cloud (Merge Step)\r\n                    // Re-fetch to ensure we have the absolute latest source of truth (including updates from other devices)\r\n                    await get().loadInitialData(userId);\r\n\r\n                } catch (e) {\r\n                    console.error(\"Sync Failed:\", e);\r\n                } finally {\r\n                    set({ isSyncing: false });\r\n                }\r\n            }\r\n        }),\r\n        {\r\n            name: 'bible-storage', // name of the item in the storage (must be unique)\r\n            storage: createJSONStorage(() => localStorage), // (optional) by default, 'localStorage' is used\r\n            partialize: (state) => ({ completedPlanIds: state.completedPlanIds, journals: state.journals }), // Only persist data, not loading states\r\n        }\r\n    )\r\n);\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\user\\Desktop\\AG\\RB\\bible-app\\src\\types\\bible.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\user\\Desktop\\AG\\RB\\bible-app\\src\\types\\supabase.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]}]
